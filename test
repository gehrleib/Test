const currentYear = new Date().getFullYear();

const after2024Div = document.getElementById('after2024');
const before2024Div = document.getElementById('before2024');

if (currentYear > 2024) {
  after2024Div.style.display = 'block'; // or 'inline' or 'flex' depending on your needs
  before2024Div.style.display = 'none';
} else {
  before2024Div.style.display = 'block'; // or 'inline' or 'flex' depending on your needs
  after2024Div.style.display = 'none';
}
