@echo off

REM Set the executable path
set "executable_path=C:\path\to\your\executable.exe"

REM Set the log directory (optional, defaults to current directory)
set "log_directory=C:\path\to\your\log\directory"

REM Create the timestamped filename
for /f "tokens=2-4 delims=/ " %%a in ('date /t') do (
  set mydate=%%c-%%a-%%b
)
for /f "tokens=1-2 delims=/:" %%a in ('time /t') do (
  set mytime=%%a-%%b
)

REM Clean up time string to be filename-safe
set mytime=%mytime: =0%
set mytime=%mytime:.=_%

set "log_file=%log_directory%\output_%mydate%_%mytime%.log"


REM Run the executable and redirect both stdout and stderr to the log file
echo Running executable: "%executable_path%" >> "%log_file%"
echo Log file: "%log_file%" >> "%log_file%"

"%executable_path%" >"%log_file%" 2>&1

echo Executable finished. >> "%log_file%"

echo.
echo Log file created: "%log_file%"
echo.

pause
