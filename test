@echo off

rem Set the full path to the logs directory
set "logdir=F:\Your\Full\Path\to\logs"

rem Check if the logs directory exists, and create it if it doesn't
if not exist "%logdir%" (
    echo Creating directory: "%logdir%"
    mkdir "%logdir%"
    if errorlevel 1 (
        echo Failed to create directory "%logdir%". Exiting.
        pause
        exit /b 1
    )
)

rem Get current date and time for log file name
for /f "tokens=2 delims==" %%a in ('wmic OS Get localdatetime /value') do set "dt=%%a"
set "logfilename=%logdir%\log_%dt:~0,4%%dt:~4,2%%dt:~6,2%_%dt:~8,2%%dt:~10,2%%dt:~12,2%.txt"

rem Display start time in the console and log file
echo Started at %dt:~0,4%-%dt:~4,2%-%dt:~6,2% %dt:~8,2%:%dt:~10,2%:%dt:~12,2% >> "%logfilename%"
echo Started at %dt:~0,4%-%dt:~4,2%-%dt:~6,2% %dt:~8,2%:%dt:~10,2%:%dt:~12,2%

rem Run the executable and redirect output and errors to the log file
echo Running your_executable.exe... >> "%logfilename%"
"path\to\your_executable.exe" >> "%logfilename%" 2>&1

rem Check for errors
if %errorlevel% neq 0 (
    echo Error occurred! Check the log file for details. >> "%logfilename%"
    echo Error occurred! Check the log file for details.
) else (
    echo Execution completed successfully. >> "%logfilename%"
    echo Execution completed successfully.
)

rem Display end time in the console and log file
for /f "tokens=2 delims==" %%a in ('wmic OS Get localdatetime /value') do set "dt=%%a"
echo Finished at %dt:~0,4%-%dt:~4,2%-%dt:~6,2% %dt:~8,2%:%dt:~10,2%:%dt:~12,2% >> "%logfilename%"
echo Finished at %dt:~0,4%-%dt:~4,2%-%dt:~6,2% %dt:~8,2%:%dt:~10,2%:%dt:~12,2%

echo Log file: "%logfilename%"
pause
