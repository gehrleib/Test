import xml.etree.ElementTree as ET

# Load and parse the XML files
tree1 = ET.parse('file1.xml')
tree2 = ET.parse('file2.xml')

# Get the root elements
root1 = tree1.getroot()
root2 = tree2.getroot()

# Create a mapping of issuanceSourceId to issuanceJurisdiction from file1
jurisdiction_map = {}
for issuance in root1.findall('issuance'):
    issuance_source_id = issuance.find('issuanceSourceId').text
    jurisdictions = [j.text for j in issuance.findall('issuanceJurisdiction')]
    jurisdiction_map[issuance_source_id] = jurisdictions

# Print the mapped data for debugging
print(f"Jurisdiction Map from file1: {jurisdiction_map}")

# For each issuance in file2, match by issuanceSourceId and append the jurisdictions
updated = False  # Flag to track if any updates are made
for issuance in root2.findall('issuance'):
    issuance_source_id = issuance.find('issuanceSourceId').text
    if issuance_source_id in jurisdiction_map:
        print(f"Match found for issuanceSourceId: {issuance_source_id}")
        # Append jurisdictions from file1 to file2
        for jurisdiction in jurisdiction_map[issuance_source_id]:
            jurisdiction_elem = ET.Element('issuanceJurisdiction')
            jurisdiction_elem.text = jurisdiction
            issuance.append(jurisdiction_elem)
            updated = True  # Mark that we have made an update

# Save the updated file2 if any updates were made
if updated:
    tree2.write('updated_file2.xml', encoding='utf-8', xml_declaration=True)
    print("Jurisdictions appended and file saved as 'updated_file2.xml'.")
else:
    print("No matching issuanceSourceId found, no updates made.")
