# In APIClient class in CUBE.py

    async def __aenter__(self):
        """
        Initializes the ClientSession and its Connector when entering an
        'async with' block, making the session available to the client instance.
        """
        # The TCPConnector controls connection pooling and behavior.
        connector = aiohttp.TCPConnector(
            limit_per_host=20,
            ttl_dns_cache=300,
            force_close=True,          # Helps prevent SSL shutdown errors.
            enable_cleanup_closed=True # Enables proactive cleanup of closed transports.
        )
        self.session = aiohttp.ClientSession(connector=connector)
        return self # Return the instance to be used in the 'async with' statement.

    async def __aexit__(self, exc_type, exc_val, exc_tb):
        """
        Closes the ClientSession gracefully when exiting the 'async with' block.
        """
        if self.session:
            await self.session.close()
        
        # This brief pause allows the event loop to properly process the
        # connection closures, preventing CancelledError on shutdown.
        await asyncio.sleep(0.1)
