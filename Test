# At the bottom of CUBE.py

async def run_script():
    """
    A wrapper function to initialize and run the APIClient using it as an
    async context manager, ensuring proper startup and shutdown.
    """
    try:
        # The 'async with' statement ensures __aenter__ is called on entry
        # and __aexit__ is called on exit, even if errors occur.
        async with APIClient() as client:
            await client.main()
    except Exception as e:
        # Catch any final, unhandled exceptions from the main logic.
        logging.critical(f"An unhandled exception occurred in the main script run: {e}", exc_info=True)
        sys.exit(1)

if __name__ == "__main__":
    asyncio.run(run_script())
    update_last_run()
