    async def fetch_section_details(self, group: dict) -> None:
        """
        Processes sections within a group if updated since the last run.

        This method fetches full section details, normalizes content, and
        concurrently fetches previous versions to generate HTML diffs. It is
        designed to be robust and handles API exceptions gracefully.
        """
        # --- Stage 1: Initial Group Date Check & Current Section Details Fetch ---
        # Retrieve and parse the group's 'updatedDate' to determine if processing is needed.
        raw_updated_date = group.get("updatedDate")
        updated_dt = None
        parsed_successfully = False

        if raw_updated_date:
            iso = raw_updated_date.replace("Z", "+00:00")
            try:
                updated_dt = datetime.fromisoformat(iso)
                parsed_successfully = True
            except ValueError:
                try:
                    # Fallback parsing for different date formats.
                    updated_dt = datetime.strptime(raw_updated_date[:19], "%Y-%m-%dT%H:%M:%S")
                    parsed_successfully = True
                except ValueError:
                    logging.warning(f"Failed to parse updatedDate '{raw_updated_date}' for group {group.get('regGroupSourceId', 'Unknown ID')}.")
        
        # If the parsed datetime is naive (no timezone), assume UTC.
        if parsed_successfully and updated_dt and updated_dt.tzinfo is None:
            updated_dt = updated_dt.replace(tzinfo=timezone.utc)

        if updated_dt and parsed_successfully:
            group["updatedDate"] = updated_dt.isoformat(timespec="milliseconds")

        # Optimization: If the group hasn't been updated since the last run, skip its processing.
        if not updated_dt or updated_dt <= LAST_RUN:
            group["section"] = []
            return

        # Fetch full details for all sections in this group, including their current content.
        section_details_response = await self.make_request(
            "POST",
            f"{API_CONNECT_URL}/api/RegSection/RegGroup?includeContent=true",
            data={"regGroup": [{"sourceId": group.get("regGroupSourceId")}]},
        )
        full_section_details_list = section_details_response.get("regSection", [])
        # Create a lookup map for efficient access to full section details by ID.
        detail_map = {d.get("sourceId"): d for d in full_section_details_list}

        original_sections_stubs = group.get("section", [])
        
        # --- Stage 2: Prepare Sections for Concurrent Diff Processing ---
        # These lists help separate sections that need a diff from those that don't.
        sections_for_diff_processing = []
        final_processed_sections_list = []

        for section_stub in original_sections_stubs:
            current_section_id = section_stub.get("sectionSourceId")
            if not (full_details := detail_map.get(current_section_id)):
                logging.error(f"Full details for section {current_section_id} not found. Skipping.")
                continue

            # Populate the section stub with enriched, normalized data.
            section_stub.update({
                "versionDate": full_details.get("versionDate"),
                "title": self._normalize_html_content(full_details.get("title")),
                "content": self._normalize_html_content(full_details.get("content")),
                "sectionLink": full_details.get("sectionLink")
            })
            # Default the diff content to the current content; it will be updated if a diff is generated.
            section_stub["contentHtmlDiff"] = section_stub["content"]

            # Determine if a diff is needed (i.e., if it's not the first version).
            if (
                current_section_id
                and (ordinal := section_stub.get("sectionVersionOrdinal"))
                and isinstance(ordinal, int) and ordinal > 1
                and section_stub["content"] is not None
            ):
                prev_version_url = f"{API_CONNECT_URL}/api/RegSection/{current_section_id}/{ordinal - 1}"
                sections_for_diff_processing.append((section_stub, prev_version_url, current_section_id))
            else:
                final_processed_sections_list.append(section_stub)
    
        # --- Stage 3: Concurrently Fetch Previous Versions and Generate Diffs ---
        if sections_for_diff_processing:
            # Create a list of asynchronous tasks to fetch all required previous versions at once.
            fetch_tasks = [self.make_request("GET", url) for _, url, _ in sections_for_diff_processing]
            
            # Execute tasks concurrently, allowing exceptions to be returned for individual handling.
            previous_versions_results = await asyncio.gather(*fetch_tasks, return_exceptions=True)

            for i, result_or_exc in enumerate(previous_versions_results):
                section_stub, _, current_section_id_for_logging = sections_for_diff_processing[i]
                
                # The backoff function already logs the final error, so we just check the type here
                # to safely handle the result without crashing.
                if not isinstance(result_or_exc, Exception):
                    # If the fetch was successful, proceed with diff generation.
                    previous_section_data_wrapper = result_or_exc
                    raw_previous_content = None
                    if previous_section_data_wrapper and isinstance(previous_section_data_wrapper.get("section"), dict):
                        raw_previous_content = previous_section_data_wrapper.get("section").get("content")

                    normalized_previous_content = self._normalize_html_content(raw_previous_content)
                    normalized_current_content = section_stub["content"]

                    if normalized_previous_content and normalized_current_content != normalized_previous_content:
                        try:
                            section_stub["contentHtmlDiff"] = self._generate_placeholder_diff(
                                normalized_previous_content,
                                normalized_current_content,
                                current_section_id_for_logging,
                            )
                        except Exception as diff_error:
                            logging.error(f"Error during diff generation for section {current_section_id_for_logging}: {diff_error}")
                
                # Add the processed section to the final list, whether its diff succeeded or failed.
                final_processed_sections_list.append(section_stub)

        # --- Stage 4: Finalize Group's Section List ---
        # Clean up temporary keys used for processing.
        for section in final_processed_sections_list:
            section.pop("bookSourceId", None)
            section.pop("sectionVersionOrdinal", None)
        
        # Prioritize keeping sections that have content.
        sections_with_content = [s for s in final_processed_sections_list if s.get("content")]
        group["section"] = sections_with_content if sections_with_content else final_processed_sections_list
