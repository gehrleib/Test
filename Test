# Load and validate environment variables
def load_and_validate_env_vars():
    """
    Load environment variables from a .env file and validate their presence.
    
    Raises:
        EnvironmentError: If any required environment variables are missing.
    """
    load_dotenv(ENV_FILE)
    required_vars = [
        'API_ID_URL', 'API_CONNECT_URL',
        'USER', 'PASSWORD', 'SCOPE', 'CLIENT_ID', 'CLIENT_SECRET'
    ]
    
    missing_vars = [var for var in required_vars if not os.getenv(var)]
    
    # Check for proxy-related environment variables if USE_PROXY is True
    if os.getenv('USE_PROXY', 'False').lower() == 'true':
        proxy_vars = ['PROXY_USERNAME', 'PROXY_PASSWORD', 'PROXY_URL']
        missing_vars.extend([var for var in proxy_vars if not os.getenv(var)])
    
    if missing_vars:
        raise EnvironmentError(f"Missing required environment variables: {', '.join(missing_vars)}")

load_and_validate_env_vars()

