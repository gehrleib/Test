<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="3.0" xmlns:xsl="http://www.w3.org/1999/XSL/Transform">
  
  <!-- Output settings -->
  <xsl:output method="xml" indent="yes" />
  
  <!-- Define templates for matching elements -->
  <xsl:template match="/Records">
    <ArcherRecords>
      <!-- Process each record -->
      <xsl:for-each select="Record/Record[@levelGuid='52008dc4-e437-4dc7-a73f-d3e04e4c740a']">
        
        <!-- Get the IDs from both fields -->
        <xsl:variable name="currentCountryIds" 
                      select="Field[@guid='5f56982d-455e-4f41-b890-55ba1eae1318']/Reference/@id" />
        <xsl:variable name="updatedCountryIds" 
                      select="../Field[@guid='9e6f3f74-8bb3-4dd8-a981-659d76a30472']/Reference/@id" />

        <!-- Convert node sets to space-separated strings for comparison -->
        <xsl:variable name="currentCountryIdsString" select="string-join($currentCountryIds, ' ')" />
        <xsl:variable name="updatedCountryIdsString" select="string-join($updatedCountryIds, ' ')" />
        
        <!-- Normalize the strings -->
        <xsl:variable name="normalizedcurrentCountryIdsString" 
                      select="normalize-space($currentCountryIdsString)" />
        <xsl:variable name="normalizedupdatedCountryIdsString" 
                      select="normalize-space($updatedCountryIdsString)" />
        
        <!-- Check if the lists are different -->
        <xsl:if test="$normalizedcurrentCountryIdsString ne $normalizedupdatedCountryIdsString">
          <ArcherRecord>
            
            <Tracking_ID>
              <xsl:value-of select="@contentId" />
            </Tracking_ID>
            
            <Previous_Value>
              <xsl:for-each select="Field[@guid='5f56982d-455e-4f41-b890-55ba1eae1318']/Reference">
                <xsl:sort select="." order="ascending" />
                <xsl:value-of select="." />
                <xsl:if test="position() != last()">
                  <xsl:text>&lt;br /&gt;&lt;br /&gt;</xsl:text>
                </xsl:if> 
              </xsl:for-each>
            </Previous_Value>
            
            <Updated_Value>
              <xsl:for-each select="../Field[@guid='9e6f3f74-8bb3-4dd8-a981-659d76a30472']/Reference">
                <xsl:sort select="." order="ascending" />
                <xsl:value-of select="." />
                <xsl:if test="position() != last()">
                  <xsl:text>&lt;br /&gt;&lt;br /&gt;</xsl:text>
                </xsl:if>
              </xsl:for-each>
            </Updated_Value>
            
            <Countrys>
              <xsl:for-each select="../Field[@guid='9e6f3f74-8bb3-4dd8-a981-659d76a30472']/Reference">
                <ReferenceId>
                  <xsl:value-of select="@id" />
                </ReferenceId>
              </xsl:for-each>
            </Countrys>

            <Primary_Jurisdiction>
              <xsl:for-each select="Field[@guid='1c0bbb5b-b2da-4ad7-9498-bc7243fa3e81']/Reference">
                <xsl:variable name="refId" select="@id" />
                <xsl:variable name="countryName" select="../../Record[@contentId=$refId]/Field[@guid='c28b9e2a-4899-477b-ae5b-54617eaa616b']/ListValues/ListValue" />
                <xsl:if test="../../../Field[@guid='9e6f3f74-8bb3-4dd8-a981-659d76a30472']/Reference[text()=$countryName]">
                  <ReferenceId>
                    <xsl:value-of select="." />
                  </ReferenceId>
                </xsl:if>
              </xsl:for-each>
            </Primary_Jurisdiction>
            
            <Cross_Border>
              <xsl:for-each select="Field[@guid='2e4c1012-9670-410d-a6a1-0746b458e0d4']/Reference">
                <xsl:variable name="refId" select="@id" />
                <xsl:variable name="countryName" select="../../Record[@contentId=$refId]/Field[@guid='c28b9e2a-4899-477b-ae5b-54617eaa616b']/ListValues/ListValue" />
                <xsl:if test="../../../Field[@guid='9e6f3f74-8bb3-4dd8-a981-659d76a30472']/Reference[text()=$countryName]">
                  <ReferenceId>
                    <xsl:value-of select="." />
                  </ReferenceId>
                </xsl:if>
              </xsl:for-each>
            </Cross_Border>
            
          </ArcherRecord>
        </xsl:if>
        
      </xsl:for-each>
    </ArcherRecords>
  </xsl:template>
  
</xsl:stylesheet>
