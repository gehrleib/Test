def update_last_run():
    """
    Update the LAST_RUN environment variable with the current timestamp.
    
    The timestamp is written to the .env file in ISO 8601 format.
    """
    last_run = datetime.now(timezone.utc).replace(hour=0, minute=0, second=0, microsecond=0).strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] + 'Z'
    with open(ENV_FILE, 'r') as file:
        lines = file.readlines()
    
    with open(ENV_FILE, 'w') as file:
        updated = False
        for line in lines:
            if line.startswith("LAST_RUN"):
                file.write(f"LAST_RUN = {last_run}\n")
                updated = True
            else:
                file.write(line)
        if not updated:
            file.write(f"LAST_RUN = {last_run}\n")

class APIClient:
    def __init__(self):
        self.token = None
        self.token_expiration = None
        self.session = None
        self.proxy = self.get_proxy()

        self.book_cache = {}
        
    def get_proxy(self) -> str:
        """
        Construct the proxy URL if proxy settings are enabled.
        
        Returns:
            str: The proxy URL, or None if proxies are not used.
        """
        if USE_PROXY:
            return f"http://{PROXY_USERNAME}:{PROXY_PASSWORD}@{PROXY_URL}"
        return None

    async def get_token(self) -> str:
        """
        Retrieve an authentication token asynchronously, refreshing it if necessary.
        
        Returns:
            str: The access token.
        """
        if self.token and self.token_expiration and time.time() < self.token_expiration - TOKEN_REFRESH_THRESHOLD:
            return self.token

        url = f"{API_ID_URL}/connect/token"
        headers = {'Content-Type': 'application/x-www-form-urlencoded'}
        data = {
            'grant_type': 'password',
            'username': os.getenv('USER'),
            'password': os.getenv('PASSWORD'),
            'scope': os.getenv('SCOPE'),
            'client_id': os.getenv('CLIENT_ID'),
            'client_secret': os.getenv('CLIENT_SECRET')
        }

        async with self.session.post(url, data=data, headers=headers, proxy=self.proxy) as response:
            response.raise_for_status()
            token_data = await response.json()
            self.token = token_data['access_token']
            self.token_expiration = time.time() + token_data['expires_in']
            return self.token

    async def fetch_with_exponential_backoff(self, func, max_retries=5, base_delay=1):
        """
        Retry a function with exponential backoff for handling transient errors.
        
        Args:
            func (Callable): The function to retry.
            max_retries (int): The maximum number of retry attempts.
            base_delay (int): The base delay in seconds before retrying.

        Returns:
            Any: The result of the function.
        """
        for retry in range(max_retries):
            try:
                return await func()
            except aiohttp.ClientError as e:
                if retry == max_retries - 1:
                    logging.error("Max retries reached. Giving up.")
                    raise
                else:
                    delay = base_delay * (2 ** retry) + random.uniform(0, 1)
                    logging.warning(f"Retry {retry + 1}/{max_retries} after {delay:.2f} seconds due to: {e}")
                    await asyncio.sleep(delay)


    async def make_request(self, method, url, data=None):
        """
        Perform an HTTP request asynchronously, handling token refresh and retries.

        Args:
            method (str): HTTP method (e.g., 'GET', 'POST').
            url (str): The URL for the request.
            data (dict, optional): The data to send with the request.

        Returns:
            dict: The response data.
        """
        headers = {
            'Connection': 'keep-alive',
            'Authorization': f'Bearer {await self.get_token()}',
            'x-page-current': '1',
            'x-page-length': '100',
            'x-custom-entity': X_CUSTOM_ENTITY,
            'Content-Type': 'application/json-patch+json',
            'api-version': "3.0"
        }

        async def _make_request():
            try:
                async with self.session.request(method, url, headers=headers, json=data, proxy=self.proxy) as response:
                    # Handle 500 Internal Server Error by refreshing token and retrying
                    if response.status == 500:
                        headers['Authorization'] = f'Bearer {await self.get_token()}'
                        async with self.session.request(method, url, headers=headers, json=data, proxy=self.proxy) as retry_response:
                            retry_response.raise_for_status()
                            return await retry_response.json()

                    response.raise_for_status()

                    # Handle pagination if applicable
                    all_responses = await response.json()

                    total_pages = int(response.headers.get('x-page-count', 1))
                    if total_pages > 1:
                        tasks = [
                            self.fetch_page(headers, page, url, data, method)
                            for page in range(2, total_pages + 1)
                        ]
                        page_results = await asyncio.gather(*tasks)
                        all_responses.extend(item for sublist in page_results for item in sublist)

                    return all_responses

            except CancelledError:
                logging.info("Request task was cancelled.")
            except aiohttp.ClientError as e:
                logging.error(f"Request failed: {e}")
                raise

        return await self.fetch_with_exponential_backoff(_make_request)

    async def fetch_page(self, headers: dict, page: int, url: str, data: dict, method: str) -> dict:
        """
        Fetch a single page of results for a paginated request.

        Args:
            headers (dict): The request headers.
            page (int): The page number to fetch.
            url (str): The URL for the request.
            data (dict): The data to send with the request.
            method (str): HTTP method (e.g., 'GET', 'POST').

        Returns:
            dict: The response data for the page.
        """
        headers['x-page-current'] = str(page)
        async with self.session.request(method, url, headers=headers, json=data, proxy=self.proxy) as page_response:
            page_response.raise_for_status()
            return await page_response.json()

    async def fetch_groups(self) -> list:
        """
        Fetch all groups.

        Returns:
            list: A list of groups.
        """
        groups = await self.make_request(
            'POST',
            API_CONNECT_URL + '/api/RegGroup/search',
            data =  {
                    "status": "publish",
                    "regGroups": [
                        # {"sourceId": "da6a6a7a-98d9-4c00-af35-49362155c4ab"},
                        # {"sourceId": "2af8f5c4-b8c8-4716-94eb-a20ad52a5c9d"},
                        # {"sourceId": "2926ead6-0a9a-4b6b-81a8-af5560f3cee0"},
                        # {"sourceId": "d9eef6f7-9f33-4247-9d3f-947942857380"},
                        
                    ]
                }
        )

        return groups

    def filter_groups(self, groups: list) -> list:
        """
        Filter groups based on specific criteria.
        
        Args:
            groups (list): List of groups to filter.
        
        Returns:
            list: A list of filtered groups.
        """
        filtered_groups = []
        keys_to_remove = {
            "attributes", "createdDate", "extract", "insight", "isLatest", "isLatestPublished", "path",
            "regGroupDescription", "regGroupStatus", "regGroupVersion", "regNarrative"
        }

        for group in groups:
            attributes = group.get('attributes', [])
            sections = group.get('section', [])
            
            # Check if any attribute has the name "Archived"
            if any(attr.get('name') == 'Archived' for attr in attributes):
                continue
            
            # Check if sections have more than one unique bookSourceId
            book_source_ids = {section.get('bookSourceId') for section in sections}
            if len(book_source_ids) != 1:
                continue

            # Remove specified keys from the group
            filtered_group = {key: value for key, value in group.items() if key not in keys_to_remove}

            # Add the bookSourceId to the filtered group
            filtered_group['issuanceSourceId'] = book_source_ids.pop()

            filtered_groups.append(filtered_group)
        
        return filtered_groups
    
    async def fetch_section_details(self, group: dict) -> None:
        """
        Process a single group, fetching additional details.

        Args:
            group (dict): The group to process.
        """
        updated_date = group.get("updatedDate")

        if updated_date and not updated_date.endswith('Z'):
            updated_date += 'Z'

        if updated_date and updated_date > LAST_RUN:
            # Fetch section details by making a POST request
            section_details_response = await self.make_request(
                'POST',
                API_CONNECT_URL + f'/api/RegSection/RegGroup?includeContent=true',
                data =  { 
                            "regGroup": [ 
                                { "sourceId": group.get("regGroupSourceId") } 
                            ] 
                        }
            )
            section_details = section_details_response.get('regSection', [])

            # Add values from section_details to each section in the group
            updated_sections = []
            for section in group.get("section", []):
                matching_details = next((detail for detail in section_details if detail['sourceId'] == section['sectionSourceId']), {})
                section['title'] = matching_details.get('title')
                section['content'] = matching_details.get('content')
                section['sectionLink'] = matching_details.get('sectionLink')

                # Remove specified keys from the section after adding the other details
                for key in ["bookSourceId", "sectionVersionOrdinal"]:
                    section.pop(key, None)

                # Only keep the section if 'content' is not empty or None
                if section['content']:
                    updated_sections.append(section)

            group['section'] = updated_sections
        else:
            group['section'] = []

    async def fetch_books(self) -> None:
        """
        Fetch all books asynchronously and store them in the cache.
        """
        books = await self.make_request(
            'POST',
            API_CONNECT_URL + "/api/RegBook/search",
            data = {}
        )

        for book in books:
            self.process_book(book)

    def process_book(self, book: dict) -> None:
        """
        Process a single book and store relevant details in the cache.

        Args:
            book (dict): The book to process.
        """
        book_id = book.get('sourceId')
        if not book_id or book_id in self.book_cache:
            return

        # Process jurisdiction if applicable
        jurisdiction = book.get('cubeApplicableJurisdiction')
        if isinstance(jurisdiction, str):
            jurisdictions = [item.strip() for item in jurisdiction.split("|")]
            processed_jurisdictions = []
            for item in jurisdictions:
                if item == "Global":
                    processed_jurisdictions = GLOBAL
                elif item in CANADIAN_PROVINCES:
                    processed_jurisdictions.append("Canada")
                elif item in US_STATES or item == "United States of America":
                    processed_jurisdictions.append("United States")
                else:
                    processed_jurisdictions.append(item)
            book['cubeApplicableJurisdiction'] = processed_jurisdictions

        # Filter and retain only the relevant keys
        book_details = {
            "issuingBodySourceId": book.get("issuingBodySourceId"),
            "issuingBodyName": book.get("issuingBodyName"),
            "issuanceSourceId": book.get("sourceId"),
            "issuanceName": book.get("title"),
            "issuanceType": book.get("issuanceTypeName"),
            "issuanceDate": book.get("issuanceDate"),
            "issuanceJurisdiction": book.get("cubeApplicableJurisdiction"),
            "issuanceLink": book.get("cubeLink"),
            "sourceLink": book.get("linkURL")
        }

        # Cache the processed book details
        self.book_cache[book_id] = book_details

    def process_and_write_updated_groups_chunks(self, groups: list, output_directory: str = "output", chunk_size: int = 100, indent: int = 4) -> None:
        """
        Process groups and write them to XML files in chunks.

        Args:
            groups (list): The list of groups to process.
        """
        issuing_bodies, issuances = self.extract_issuing_body_and_issuance_data(groups)

        # Write each data list to its own XML file within the output directory
        for data, filename_prefix in [
            (issuing_bodies, "issuingBody"),
            (issuances, "issuance"),
            (groups, "group"),
        ]:
            self.write_xml_file(data, filename_prefix, output_directory, chunk_size, indent)

    def extract_issuing_body_and_issuance_data(self, groups: list) -> tuple:
        """
        Extract issuing body and issuance data from groups.

        Args:
            groups (list): The list of groups to process.

        Returns:
            tuple: Two lists, one with issuing bodies and another with issuances.
        """
        issuing_bodies = {}
        issuances = {}

        for group in groups:
            issuance_source_id = group.get("issuanceSourceId")

            if issuance_source_id and issuance_source_id in self.book_cache:
                book_data = self.book_cache[issuance_source_id]

                # Add issuing body details
                issuing_body_source_id = book_data.get("issuingBodySourceId")
                if issuing_body_source_id:
                    issuing_bodies[issuing_body_source_id] = {
                        "issuingBodySourceId": issuing_body_source_id,
                        "issuingBodyName": book_data["issuingBodyName"]
                    }

                # Add issuance details
                issuances[issuance_source_id] = {
                    **{
                        key: value
                        for key, value in book_data.items()
                        if key not in ["issuingBodyName"]
                    }
                }

        return list(issuing_bodies.values()), list(issuances.values())

    def pluralize(self, word: str) -> str:
        """
        Convert a singular noun to its plural form.
        
        Rules applied:
        - Words ending in 'y' are converted to 'ies'.
        - Words ending in 's', 'x', 'z', 'ch', or 'sh' are converted by adding 'es'.
        - All other words are converted by adding 's'.
        
        Args:
        word (str): The singular noun to be pluralized.
        
        Returns:
        str: The pluralized form of the input word.
        """
        # Check if the word is already plural
        if word.endswith('ies') or word.endswith('es') or word.endswith('s'):
            return word  # Assume the word is already plural
        
        if word.endswith('y'):
            return word[:-1] + 'ies'
        elif word.endswith(('s', 'x', 'z', 'ch', 'sh')):
            return word + 'es'
        else:
            return word + 's'

    def write_xml_file(self, data: list, filename_prefix: str, output_directory: str = "output", chunk_size: int = 100, indent: int = 4) -> None:
        """
        Writes the given data to an XML file, ensuring that the output directory exists.

        Args:
            data (list): The data to write to the XML file.
            filename_prefix (str): The prefix for the output file name.
            output_directory (str): The directory where the output file will be saved.
            chunk_size (int): The number of items to include in each file chunk.
            indent (int): The number of spaces for XML indentation.
        """
        # Ensure the output directory exists
        os.makedirs(output_directory, exist_ok=True)

        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
        output_file = os.path.join(output_directory, f"{filename_prefix}_{timestamp}.xml")
        temp_file = output_file + ".tmp"
        root_element = filename_prefix  # Use the prefix as root element name

        try:
            with open(temp_file, 'w', encoding='utf-8') as outfile:
                outfile.write('<?xml version="1.0" encoding="utf-8"?>\n')
                outfile.write(f'<{self.pluralize(root_element)} count="{len(data)}">\n')  # Use pluralized root element

                # Process and write data in chunks
                for i in range(0, len(data), chunk_size):
                    chunk = data[i:i + chunk_size]

                    for item in chunk:
                        item_xml = xmltodict.unparse({root_element: item}, pretty=True)
                        item_xml = item_xml.replace('<?xml version="1.0" encoding="utf-8"?>', '').strip()

                        # Ensure proper indentation
                        item_xml = item_xml.strip()
                        lines = item_xml.split('\n')
                        indented_lines = [lines[0]]
                        for line in lines[1:]:
                            indented_lines.append(' ' * indent + line)
                        indented_item_xml = '\n'.join(indented_lines)

                        outfile.write(f'{" " * indent}{indented_item_xml}\n') 

                outfile.write(f'</{self.pluralize(root_element)}>')

            shutil.move(temp_file, output_file)
            logging.info(f"Data successfully written to {output_file}")

        except IOError as e:
            logging.error(f"Error writing to file: {e}")
            if os.path.exists(temp_file):
                os.remove(temp_file)

        except Exception as e:
            logging.error(f"An unexpected error occurred: {e}")
            if os.path.exists(temp_file):
                os.remove(temp_file)

    async def main(self):
        start_time = time.perf_counter()

        async with aiohttp.ClientSession() as self.session:

            groups = self.filter_groups(await self.fetch_groups())
            
            # fetch additional section details for groups in chunks
            chunk_size = 25
            for i in range(0, len(groups), chunk_size):
                chunk = groups[i:i + chunk_size]
                await asyncio.gather(*(self.fetch_section_details(group) for group in chunk))
            
            # fetch books and store in cache
            await self.fetch_books()

            groupUpdates = [group for group in groups if group.get("section")]
            self.process_and_write_updated_groups_chunks(groupUpdates)

            activeGroupIds = [{ "regGroupSourceId": group.get("regGroupSourceId") } for group in groups]
            self.write_xml_file(activeGroupIds, "activeGroup")

        end_time = time.perf_counter()
        total_runtime = end_time - start_time

        minutes = int(total_runtime // 60)
        seconds = int(total_runtime % 60)

        logging.info(f"Total runtime: {minutes} minutes and {seconds} seconds")

if __name__ == "__main__":
    client = APIClient()
    asyncio.run(client.main())
    update_last_run()
