    async def get_token(self, force_refresh: bool = False) -> str:
        """
        Retrieves a valid authentication token, using a lock and a cooldown
        timestamp to prevent race conditions from multiple concurrent requests.
        """
        # First, acquire the lock to ensure only one task can check or refresh
        # the token at a time.
        async with self._token_lock:
            # Check if a forced refresh is requested, but one just happened.
            # This is the cooldown logic that solves the race condition.
            if force_refresh and self.last_token_refresh_time:
                time_since_last_refresh = time.time() - self.last_token_refresh_time
                if time_since_last_refresh < 15:  # 15-second cooldown period
                    logging.debug(
                        f"Forced refresh requested, but a refresh occurred {time_since_last_refresh:.1f}s ago. "
                        "Using existing token."
                    )
                    if self.token:
                        return self.token

            # After handling the cooldown, check if the current token is still valid.
            if not force_refresh and self.token and self.token_expiration and \
               time.time() < self.token_expiration - TOKEN_REFRESH_THRESHOLD:
                return self.token

            # If we are here, we must fetch a new token.
            if self.session is None:
                raise RuntimeError("ClientSession not initialized.")

            logging.info("Fetching new API token...")
            url = f"{API_ID_URL}/connect/token"
            headers = {"Content-Type": "application/x-www-form-urlencoded"}
            data = {
                "grant_type": "password",
                "username": os.getenv("USER"),
                "password": os.getenv("PASSWORD"),
                "scope": os.getenv("SCOPE"),
                "client_id": os.getenv("CLIENT_ID"),
                "client_secret": os.getenv("CLIENT_SECRET"),
            }

            async with self.session.post(url, data=data, headers=headers, proxy=self.proxy) as response:
                response.raise_for_status()
                text_content = await response.text()
                token_data = orjson.loads(text_content)

                self.token = token_data["access_token"]
                self.token_expiration = time.time() + token_data["expires_in"]
                # Update the timestamp after every successful refresh.
                self.last_token_refresh_time = time.time()
                
                logging.info("Successfully fetched new API token.")
                return self.token
