import argparse

def diagnose_file(file_path: str):
    """
    Reads a log file and prints a raw, diagnostic representation of lines
    that contain the key phrase "Skipping Group ID".

    Args:
        file_path: The path to the log file to diagnose.
    """
    key_phrase = "Skipping Group ID"
    lines_found = 0
    
    print(f"\n--- Running Diagnostics on: {file_path} ---\n")
    
    try:
        # Open the file in binary mode to see the raw bytes
        with open(file_path, 'rb') as f:
            for i, line_bytes in enumerate(f, 1):
                # Decode each line individually, ignoring errors
                line_str = line_bytes.decode('utf-8', errors='ignore')
                
                if key_phrase.lower() in line_str.lower():
                    lines_found += 1
                    if lines_found <= 10: # Only print the first 10 matches
                        print(f"Match found on line {i}:")
                        # repr() will show invisible characters like \n, \t, etc.
                        print(f"  - Raw representation: {repr(line_str)}")
                        print("-" * 20)
                        
    except FileNotFoundError:
        print(f"Error: The file '{file_path}' was not found.")
        return
        
    if lines_found > 0:
        print(f"\nDiagnostic complete. Found the key phrase in {lines_found} lines.")
    else:
        print("\nDiagnostic complete. The key phrase 'Skipping Group ID' was not found in any line.")

if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description="Diagnose a log file for hidden characters or formatting issues."
    )
    parser.add_argument("log_file", help="The path to the log file to diagnose.")
    
    args = parser.parse_args()
    diagnose_file(args.log_file)
