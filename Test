<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" version="1.0">

   <!-- Output an XML document -->
   <xsl:output method="xml" indent="yes"/>
   
   <xsl:template match="/">
      <ArcherRecords>
         <!-- Loop through each Record in the input XML -->
         <xsl:for-each select="Records/Record">
            <!-- Store the value of currentValue -->
            <xsl:variable name="currentValue" select="Field[@guid='a05e33a4-c08f-4494-a3f1-5c807815bb17']/ListValues/ListValue" />
            <!-- Store the value of updatedValue (Field with guid='34417574-208c-4c59-b9c8-27ab93ed6274') -->
            <xsl:variable name="updatedValue" select="Record/Field[@guid='34417574-208c-4c59-b9c8-27ab93ed6274']/ListValues/ListValue" />
            
            <!-- Check both conditions: currentValue is "No" or missing, AND updatedValue is "Yes" -->
            <xsl:if test="(not($currentValue) or $currentValue = 'No') and $updatedValue = 'Yes'">
               <ArcherRecord>
                  <!-- Copy the Field with ID 23580 -->
                  <xsl:copy-of select="Field[@guid='5a67cd15-0c58-4b82-aa23-d8aa148a38c4']" />
                  
                  <!-- Output Previous_Value (currentValue) and Updated_Value (updatedValue) -->
                  <Previous_Value>
                     <xsl:value-of select="$currentValue" />
                  </Previous_Value>
                  <Updated_Value>
                     <xsl:value-of select="$updatedValue" />
                  </Updated_Value>
               </ArcherRecord>
            </xsl:if>
         </xsl:for-each>
      </ArcherRecords>
   </xsl:template>
</xsl:stylesheet>
