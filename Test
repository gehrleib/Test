    def filter_groups(self, groups: list) -> list:
        """
        Filter groups based on specific criteria.

        Args:
            groups (list): List of groups to filter.

        Returns:
            list: A list of filtered groups.
        """
        filtered_groups = []
        keys_to_remove = {
            "attributes",
            "createdBy",
            "createdDate",
            "extract",
            "hasChildren",
            "insight",
            "isLatest",
            "isLatestPublished",
            "path",
            "parentSourceId",
            "regGroupDescription",
            "regGroupStatus",
            "regGroupVersion",
            "regNarrative",
            "updatedBy",
        }

        for group in groups:
            group_id = group.get("regGroupSourceId", "Unknown ID")
            attributes = group.get("attributes", [])
            sections = group.get("section", [])

            # Check if any attribute has the name "Archived"
            if any(attr.get("name") == "Archived" for attr in attributes):
                continue

            # Check if sections have more than one unique bookSourceId
            book_source_ids = {section.get("bookSourceId") for section in sections}
            count_book_source_ids = len(book_source_ids)

            if count_book_source_ids == 0:
                logging.info(
                    f"Skipping group {group_id} because its sections have no bookSourceIds."
                )
                continue
            elif count_book_source_ids > 1:
                logging.info(
                    f"Skipping group {group_id} because its sections have multiple ({count_book_source_ids}) distinct bookSourceIds."
                )
                continue

            # At this point, count_book_source_ids is 1
            # Pop the single element from the set to get the issuance_id
            issuance_id = book_source_ids.pop()

            # If the unique bookSourceId is None, skip this group.
            if issuance_id is None:
                logging.warning(
                    f"Skipping group {group_id} due to missing valid issuanceSourceId (was None)."
                )
                continue

            # Remove specified keys from the group
            filtered_group = {
                key: value for key, value in group.items() if key not in keys_to_remove
            }

            # Add the bookSourceId to the filtered group
            filtered_group["issuanceSourceId"] = issuance_id

            filtered_groups.append(filtered_group)

        return filtered_groups

    def _normalize_html_content(self, content_input: Optional[str]) -> Optional[str]:
        """
        Applies a series of normalizations to an HTML content string to prepare it
        for storage and for consistent diffing.
        """
        if content_input is None:
            return None

        processed_str = str(content_input)

        # 1. Normalize common typographic characters to standard equivalents.
        processed_str = processed_str.replace("’", "'").replace(
            "‘", "'"
        )  # Curly single quotes to apostrophe
        processed_str = processed_str.replace("“", '"').replace(
            "”", '"'
        )  # Curly double quotes to standard double quote
        processed_str = processed_str.replace(
            "‐", "-"
        )  # U+2010 HYPHEN to U+002D HYPHEN-MINUS

        # 2. Standardize general whitespace: convert newlines to spaces, then collapse multiple spaces.
        processed_str = processed_str.replace("\n", " ")
        processed_str = re.sub(r"\s+", " ", processed_str)

        # 3. Apply custom tag transformations (e.g., <url> to <a>).
        processed_str = processed_str.replace("<url link=", '<a target="_blank" href=')
        processed_str = processed_str.replace("</url>", "</a>")

        # 4. Remove specific diff formatting artifacts if they are present from other systems.
        ins_start_tag = '<ins class="diffins">'
        if processed_str.startswith(ins_start_tag):
            processed_str = processed_str[len(ins_start_tag) :]
        ins_end_tag = "</ins>"
        if processed_str.endswith(ins_end_tag):
            processed_str = processed_str[: -len(ins_end_tag)]

        # 5. Remove <span> tags that are semantically empty (i.e., empty or contain only whitespace),
        #    even if they have attributes.
        processed_str = SPAN_EMPTY_RE.sub("", processed_str)

        # 6. Unwrap content from plain (attribute-less) <span> tags.
        #    This changes "<span>text</span>" to "text". Loop to handle nested plain spans.
        current_str = processed_str
        while True:
            next_str = SPAN_UNWRAP_RE.sub(r"\1", current_str)
            if next_str == current_str:  # No more changes, unwrapping is complete
                processed_str = next_str
                break
            current_str = next_str  # Continue with the unwrapped string

        # 7. Normalize whitespace around <p> tags.
        # Remove whitespace immediately following an opening <p> tag.
        processed_str = P_TAG_WS_OPEN_RE.sub(r"\1", processed_str)
        # Remove whitespace immediately before a closing </p> tag.
        processed_str = P_TAG_WS_CLOSE_RE.sub(r"\1", processed_str)

        # 8. Trim leading/trailing whitespace from the entire processed string.
        return processed_str.strip()

    def _generate_placeholder_diff(
        self, previous_html: str, current_html: str, section_id_for_logging: str
    ) -> str:
        """
        Generates an HTML diff string using diff-match-patch with a placeholder strategy
        to protect HTML tag integrity.
        Assumes input HTML strings are already normalized.
        """
        # a) Find all unique HTML tags in both strings, preserving order of first appearance.
        tags_from_prev = TAG_RE.findall(previous_html)
        tags_from_curr = TAG_RE.findall(current_html)
        all_found_tags = tags_from_prev + tags_from_curr
        unique_tags = list(dict.fromkeys(all_found_tags))  # Preserves order

        # b) Map each unique tag to a Private Use Area (PUA) Unicode character.
        tag_to_placeholder = {}
        placeholder_to_tag = {}
        # PUA range E000–F8FF offers 6400 codepoints.
        if len(unique_tags) > MAX_PUA_TAGS:
            logging.error(
                f"Too many unique HTML tags ({len(unique_tags)}) for PUA placeholder strategy in section {section_id_for_logging}. Cannot generate reliable diff."
            )
            raise ValueError(
                "Exceeded maximum number of unique tags for PUA placeholder strategy."
            )

        for i, tag_str in enumerate(unique_tags):
            placeholder_char = chr(0xE000 + i)
            tag_to_placeholder[tag_str] = placeholder_char
            placeholder_to_tag[placeholder_char] = tag_str

        # c) Replace tags with placeholders in copies of the strings.
        prev_with_placeholders = previous_html
        curr_with_placeholders = current_html
        if unique_tags:
            sorted_tags_for_regex = sorted(
                tag_to_placeholder.keys(), key=len, reverse=True
            )
            tag_placeholder_re = re.compile(
                "|".join(map(re.escape, sorted_tags_for_regex))
            )

            prev_with_placeholders = tag_placeholder_re.sub(
                lambda m: tag_to_placeholder[m.group(0)], previous_html
            )
            curr_with_placeholders = tag_placeholder_re.sub(
                lambda m: tag_to_placeholder[m.group(0)], current_html
            )

        # d) Run diff-match-patch on the placeholder-laden strings.
        dmp = dmp_module.diff_match_patch()
        diffs = dmp.diff_main(prev_with_placeholders, curr_with_placeholders)
        dmp.diff_cleanupSemantic(diffs)  # Makes the diff more human-readable.
        html_diff_with_placeholders = dmp.diff_prettyHtml(diffs)

        # e) Unescape the HTML output from diff_prettyHtml (handles entities in text).
        unescaped_html = html.unescape(html_diff_with_placeholders)

        # Remove ALL span tags (e.g., <span style="...">, <span>, </span>)
        # that diff_prettyHtml might have added around equal segments or for other styling.
        cleaned_html_diff = SPAN_CLEANUP_RE.sub("", unescaped_html)

        # f) Restore placeholders back to their original HTML tags.
        #    Iterate by longest placeholder first if placeholders were multi-character (not critical for single PUA chars).
        final_diff_html = cleaned_html_diff
        if placeholder_to_tag:
            # PUA chars generally don't need re.escape for the pattern, but it's safer.
            # Sort by length desc for robustness if placeholders could be substrings (not an issue for single PUA chars).
            sorted_placeholders_for_regex = sorted(
                placeholder_to_tag.keys(), key=len, reverse=True
            )
            placeholder_restore_re = re.compile(
                "|".join(map(re.escape, sorted_placeholders_for_regex))
            )
            final_diff_html = placeholder_restore_re.sub(
                lambda m: placeholder_to_tag[m.group(0)], cleaned_html_diff
            )

        return final_diff_html

    async def fetch_section_details(self, group: dict) -> None:
        """
        Processes sections within a group if updated since LAST_RUN.
        Fetches full section details, normalizes content and titles,
        and generates an HTML diff for 'contentHtmlDiff' if changes occurred.
        """
        # --- Stage 1: Initial Group Date Check & Current Section Details Fetch ---

        raw_updated_date = group.get("updatedDate")
        if raw_updated_date:
            # 1) Convert any trailing "Z" → "+00:00" so fromisoformat can consume it as an offset
            iso = raw_updated_date.replace("Z", "+00:00")

            # 2) Parse; if there was no offset your dt.tzinfo will be None
            try:
                updated_dt = datetime.fromisoformat(iso)
            except ValueError:
                # fallback for totally unexpected formats
                updated_dt = datetime.strptime(
                    raw_updated_date[:19], "%Y-%m-%dT%H:%M:%S"
                )

            # 3) If we got a naive dt, assume UTC
            if updated_dt.tzinfo is None:
                updated_dt = updated_dt.replace(tzinfo=timezone.utc)
        else:
            updated_dt = None

        if updated_dt:  # Only set updatedDate if we successfully parsed it
            group["updatedDate"] = updated_dt.isoformat(timespec="milliseconds")

        # Only process if the group was updated since the last run
        if not updated_dt or updated_dt <= LAST_RUN:
            group["section"] = []  # Ensure 'section' key exists but is empty
            return  # Exit early

        # Fetch full details for all sections within this specific group.
        # This API call includes the content for the *current* version of each section.
        # 'includeContent=true' ensures section text is returned.
        section_details_response = await self.make_request(
            "POST",
            API_CONNECT_URL + f"/api/RegSection/RegGroup?includeContent=true",
            data={"regGroup": [{"sourceId": group.get("regGroupSourceId")}]},
        )
        # Extract the list of section details from the API response.
        full_section_details_list = section_details_response.get("regSection", [])

        # Create a dictionary for quick lookup of full section details by their sourceId.
        # This avoids repeatedly searching the list later.
        detail_map = {d.get("sourceId"): d for d in full_section_details_list}

        # Get the list of section stubs originally part of the group data.
        # These stubs typically contain identifiers and version ordinals but not full content.
        original_sections_stubs = group.get("section", [])

        # --- Stage 2: Prepare Sections and Identify Those Needing Previous Versions ---

        # List to store tuples: (section_stub, prev_version_url, current_section_id)
        # for sections that require fetching a previous version for diffing.
        sections_for_diff_processing = []

        # List to hold section stubs that have been processed (either diffed or not needing a diff).
        final_processed_sections_list = []

        # Iterate over each section stub from the input group data.
        for section_stub in original_sections_stubs:
            current_section_id = section_stub.get("sectionSourceId")
            current_section_version_ordinal = section_stub.get("sectionVersionOrdinal")

            # Retrieve the full details for the current section using the detail_map.
            full_details = detail_map.get(current_section_id)

            if full_details is None:
                # If full details are missing (e.g., data inconsistency), log an error and skip this stub.
                logging.error(
                    f"Full details for section {current_section_id} (version {current_section_version_ordinal}) not found. Skipping this section stub."
                )
                continue  # Move to the next section stub

            # Populate the section_stub with details from the fetched full_details (current version).
            # This includes version date, normalized title, and normalized content.
            section_stub["versionDate"] = full_details.get("versionDate")
            section_stub["title"] = self._normalize_html_content(
                full_details.get("title")
            )
            section_stub["content"] = self._normalize_html_content(
                full_details.get("content")
            )
            # Default 'contentHtmlDiff' to the current normalized content. It will be updated if a diff is generated.
            section_stub["contentHtmlDiff"] = section_stub["content"]
            section_stub["sectionLink"] = full_details.get("sectionLink")

            # Determine if a diff needs to be generated for this section.
            # Conditions:
            # 1. Valid section ID and version ordinal.
            # 2. Version ordinal is an integer greater than 1 (meaning a previous version exists).
            # 3. Current content is not None (cannot diff if there's no current content).
            needs_diff = (
                current_section_id
                and current_section_version_ordinal
                and isinstance(current_section_version_ordinal, int)
                and current_section_version_ordinal > 1
                and section_stub["content"] is not None
            )

            if needs_diff:
                # If a diff is needed, calculate the version number of the previous section.
                version_to_fetch = current_section_version_ordinal - 1
                # Construct the API URL to fetch the specific previous version of the section.
                prev_version_url = f"{API_CONNECT_URL}/api/RegSection/{current_section_id}/{version_to_fetch}"
                # Add the section stub and necessary info to the list for batch processing.
                sections_for_diff_processing.append(
                    (section_stub, prev_version_url, current_section_id)
                )
            else:
                # If no diff is needed (e.g., it's version 1, content is None, or IDs are missing):
                # Clean up keys that are not needed in the final output for this section.
                keys_to_pop = ["bookSourceId", "sectionVersionOrdinal"]
                for key in keys_to_pop:
                    section_stub.pop(key, None)
                # Add the already processed section stub to the final list.
                final_processed_sections_list.append(section_stub)

        # --- Stage 3: Concurrently Fetch Previous Versions and Generate Diffs ---

        # Check if there are any sections that require fetching their previous versions.
        if sections_for_diff_processing:
            # Create a list of asynchronous tasks to fetch previous section versions.
            # Each task is a coroutine call to `self.make_request`.
            fetch_tasks = [
                self.make_request("GET", url)
                for _, url, _ in sections_for_diff_processing
            ]

            # Execute all fetch_tasks concurrently using asyncio.gather.
            # `return_exceptions=True` ensures that if one task fails, others can complete,
            # and the exception is returned as a result instead of raising it immediately.
            previous_versions_results = await asyncio.gather(
                *fetch_tasks, return_exceptions=True
            )

            # Process the results of the concurrent fetches.
            for i, result_or_exc in enumerate(previous_versions_results):
                # Retrieve the corresponding section_stub and ID for logging.
                section_stub, _, current_section_id_for_logging = (
                    sections_for_diff_processing[i]
                )

                if isinstance(result_or_exc, Exception):
                    # If fetching the previous version resulted in an exception (e.g., API error, 404):
                    # Log the error. The 'contentHtmlDiff' will remain as the current content (default).
                    logging.error(
                        f"API error fetching previous version for section {current_section_id_for_logging}: {result_or_exc}. "
                        f"contentHtmlDiff remains as current_content."
                    )
                else:
                    # If the previous version was fetched successfully:
                    previous_section_data_wrapper = (
                        result_or_exc  # This is the API response data
                    )
                    raw_previous_content = None
                    # Extract the 'content' from the previous section's data.
                    if previous_section_data_wrapper and isinstance(
                        previous_section_data_wrapper.get("section"), dict
                    ):
                        raw_previous_content = previous_section_data_wrapper.get(
                            "section"
                        ).get("content")

                    # Normalize the HTML content of the previous version.
                    normalized_previous_content = self._normalize_html_content(
                        raw_previous_content
                    )
                    # Current content is already normalized and stored in section_stub["content"].
                    normalized_current_content = section_stub["content"]

                    # Proceed with diff generation only if previous content is available.
                    # (Current content was already checked for None before adding to sections_for_diff_processing).
                    if normalized_previous_content is not None:
                        # Generate diff only if current and previous content are actually different.
                        if normalized_current_content != normalized_previous_content:
                            try:
                                # Call the placeholder-based diff generation method.
                                section_stub["contentHtmlDiff"] = (
                                    self._generate_placeholder_diff(
                                        normalized_previous_content,
                                        normalized_current_content,
                                        current_section_id_for_logging,  # Used for logging within the diff function
                                    )
                                )
                            except ValueError as ve:
                                # Handle specific errors from _generate_placeholder_diff (e.g., too many tags).
                                logging.error(
                                    f"{ve} for section {current_section_id_for_logging}. contentHtmlDiff remains as current_content."
                                )
                            except Exception as diff_error:
                                # Handle any other unexpected errors during diff generation.
                                logging.error(
                                    f"Error during placeholder-based diff for section {current_section_id_for_logging}: {diff_error}. "
                                    f"contentHtmlDiff remains as current_content."
                                )
                    # If normalized_previous_content is None, 'contentHtmlDiff' remains as current_content (default).

                # Clean up keys from the section_stub after processing.
                keys_to_pop = ["bookSourceId", "sectionVersionOrdinal"]
                for key in keys_to_pop:
                    section_stub.pop(key, None)
                # Add the fully processed (diffed or error-handled) section stub to the final list.
                final_processed_sections_list.append(section_stub)

        # --- Stage 4: Finalize Group's Section List ---

        # Filter the processed sections: only include those that have actual content.
        # This prevents sections with null/empty content from cluttering the output,
        # unless no sections with content exist, in which case all processed sections are kept.
        sections_with_content = [
            s for s in final_processed_sections_list if s.get("content")
        ]

        if sections_with_content:
            # If there are sections with content, use them.
            group["section"] = sections_with_content
        elif final_processed_sections_list:
            # Otherwise, if there are processed sections (even without content), use them.
            # This handles cases where all sections might have their content legitimately removed.
            group["section"] = final_processed_sections_list
        else:
            # If original_sections_stubs was empty or all were skipped (e.g., due to missing details),
            # ensure 'section' is an empty list.
            group["section"] = []

    async def fetch_books(self) -> None:
        """
        Fetch all books asynchronously and store them in the cache.
        """
        books = await self.make_request(
            "POST", API_CONNECT_URL + "/api/RegBook/search", data={}
        )

        for book in books:
            self.process_book(book)

    def process_book(self, book: dict) -> None:
        """
        Process a single book and store relevant details in the cache.

        Args:
            book (dict): The book to process.
        """
        book_id = book.get("sourceId")
        if not book_id or book_id in self.book_cache:
            return

        # Process jurisdiction if applicable
        jurisdiction = book.get("cubeApplicableJurisdiction")
        processed_jurisdictions = []
        if isinstance(jurisdiction, str):
            jurisdictions_list = [item.strip() for item in jurisdiction.split("|")]
            temp_processed_jurisdictions = (
                set()
            )  # Use a set to handle potential duplicates before list conversion
            is_global_or_supranational = False
            for item in jurisdictions_list:
                if item == "Global" or item == "Supranational":
                    is_global_or_supranational = True
                    break  # Global overrides others
                elif item in CANADIAN_PROVINCES:
                    temp_processed_jurisdictions.add("Canada")
                elif item in US_STATES or item == "United States of America":
                    temp_processed_jurisdictions.add("United States")
                elif item:  # Add non-empty, non-specific items
                    temp_processed_jurisdictions.add(item)

            if is_global_or_supranational:
                processed_jurisdictions = GLOBAL  # Assign the frozenset directly
            else:
                processed_jurisdictions = sorted(
                    list(temp_processed_jurisdictions)
                )  # Convert set to sorted list

        book["cubeApplicableJurisdiction"] = processed_jurisdictions

        # Filter and retain only the relevant keys
        book_details = {
            "issuingBodySourceId": book.get("issuingBodySourceId"),
            "issuingBodyName": book.get("issuingBodyName"),
            "issuanceSourceId": book.get("sourceId"),
            "issuanceName": book.get("title"),
            "issuanceType": book.get("issuanceTypeName"),
            "issuanceDate": book.get("issuanceDate"),
            "issuanceJurisdiction": book.get("cubeApplicableJurisdiction"),
            "issuanceLink": book.get("cubeLink"),
            "sourceLink": book.get("linkURL"),
        }

        # Cache the processed book details
        self.book_cache[book_id] = book_details

    def process_and_write_updated_groups_chunks(
        self,
        groups: list,
        output_directory: str = os.path.join(EXECUTABLE_DIR, "output"),
        chunk_size: int = 100,
        indent: int = 4,
    ) -> None:
        """
        Process groups and write them to XML files in chunks.

        Args:
            groups (list): The list of groups to process.
        """
        issuing_bodies, issuances = self.extract_issuing_body_and_issuance_data(groups)

        # Write each data list to its own XML file within the output directory
        for data, filename_prefix in [
            (issuing_bodies, "issuingBody"),
            (issuances, "issuance"),
            (groups, "group"),
        ]:
            self.write_xml_file(
                data, filename_prefix, output_directory, chunk_size, indent
            )

    def extract_issuing_body_and_issuance_data(self, groups: list) -> tuple:
        """
        Extract issuing body and issuance data from groups.

        Args:
            groups (list): The list of groups to process.

        Returns:
            tuple: Two lists, one with issuing bodies and another with issuances.
        """
        issuing_bodies = {}
        issuances = {}

        for group in groups:
            issuance_source_id = group.get("issuanceSourceId")

            if issuance_source_id and issuance_source_id in self.book_cache:
                book_data = self.book_cache[issuance_source_id]

                # Add issuing body details
                issuing_body_source_id = book_data.get("issuingBodySourceId")
                if issuing_body_source_id:
                    issuing_bodies[issuing_body_source_id] = {
                        "issuingBodySourceId": issuing_body_source_id,
                        "issuingBodyName": book_data["issuingBodyName"],
                    }

                # Add issuance details
                issuances[issuance_source_id] = {
                    **{
                        key: value
                        for key, value in book_data.items()
                        if key not in ["issuingBodyName"]
                    }
                }

        return list(issuing_bodies.values()), list(issuances.values())

    def pluralize(self, word: str) -> str:
        """
        Convert a singular noun to its plural form.

        Rules applied:
        - Words ending in 'y' are converted to 'ies'.
        - Words ending in 's', 'x', 'z', 'ch', or 'sh' are converted by adding 'es'.
        - All other words are converted by adding 's'.

        Args:
        word (str): The singular noun to be pluralized.

        Returns:
        str: The pluralized form of the input word.
        """
        if not word:
            return ""  # Handle empty string case

        # Check if the word is already plural
        if word.lower().endswith("s"):  # A simple check, can be improved
            # check for common exceptions like 'status' -> 'statuses'
            if word.lower() in ["status", "Status"]:
                return word + "es"
            if word.lower().endswith("ies") or word.lower().endswith("es"):
                return word
            # if it ends with 's' but not 'ss' (like 'bus' -> 'buses')
            if not word.lower().endswith("ss"):
                # For words like 'group's' (possessive), this might be tricky.
                # For now, if it ends with s and isn't ies/es, assume plural or handle common cases.
                # This simple check is not perfect.
                # A word like "process" would incorrectly be returned as "process" by this logic
                # if it wasn't for the 'es' rule below.
                pass  # Fall through to other rules for cases like "bus"

        if word.endswith("y"):
            if (
                len(word) > 1 and word[-2].lower() not in "aeiou"
            ):  # e.g. "city" -> "cities", "boy" -> "boys"
                return word[:-1] + "ies"
            else:
                return word + "s"
        elif word.endswith(("s", "x", "z", "ch", "sh")):
            return word + "es"
        else:
            return word + "s"

    def write_xml_file(
        self,
        data: list,
        filename_prefix: str,
        output_directory: str = os.path.join(EXECUTABLE_DIR, "output"),
        chunk_size: int = 100,
        indent_spaces: int = 4,
    ) -> None:
        """
        Writes the given data to an XML file, ensuring that the output directory exists.

        Args:
            data (list): The data to write to the XML file.
            filename_prefix (str): The prefix for the output file name.
            output_directory (str): The directory where the output file will be saved.
            chunk_size (int): The number of items to include in each file chunk.
            indent (int): The number of spaces for XML indentation.
        """
        # Ensure the output directory exists
        os.makedirs(output_directory, exist_ok=True)

        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        output_file = os.path.join(
            output_directory, f"{filename_prefix}_{timestamp}.xml"
        )
        temp_file = output_file + ".tmp"

        # Determine the singular item name (root_element for each item)
        # This assumes filename_prefix is the singular form, e.g., "group"
        item_element_name = filename_prefix
        # Pluralize for the root container element, e.g., "groups"
        root_container_name = self.pluralize(filename_prefix)

        xml_data_structure = {
            root_container_name: {
                item_element_name: data,
                "@count": str(len(data)),  # Add count attribute to the root
            }
        }

        try:
            # Generate the full XML string using xmltodict.unparse
            # `pretty=True` and `indent` handle the overall structure.
            # `full_document=True` adds the XML declaration.
            xml_string = xmltodict.unparse(
                xml_data_structure,
                pretty=True,
                indent=" " * indent_spaces,
                full_document=True,
            )

            with open(temp_file, "w", encoding="utf-8") as outfile:
                outfile.write(xml_string)

            shutil.move(temp_file, output_file)
            logging.info(f"Data successfully written to {output_file}")

        except IOError as e:
            logging.error(f"Error writing to file {output_file}: {e}")
            if os.path.exists(temp_file):
                os.remove(temp_file)
        except Exception as e:  # Catch other errors like those from xmltodict
            logging.error(
                f"An unexpected error occurred while writing {output_file}: {e}"
            )
            if os.path.exists(temp_file):
                os.remove(temp_file)
                os.remove(temp_file)

    async def main(self):
        start_time = time.perf_counter()

        connector = aiohttp.TCPConnector(
            limit_per_host=20,  # max concurrent connections per host
            ttl_dns_cache=300,  # cache DNS entries for 5 minutes
        )

        async with aiohttp.ClientSession(connector=connector) as self.session:

            # Fetch groups first
            raw_groups = await self.fetch_groups()

            # Check if raw_groups is empty
            if not raw_groups:
                logging.error(
                    "API returned a 200 OK status but no groups were fetched. Aborting script to prevent empty XML generation."
                )
                sys.exit("No groups fetched from API.")  # Exit the script

            # If groups were fetched, proceed with filtering
            groups = self.filter_groups(raw_groups)

            # fetch additional section details for groups in chunks
            chunk_size = 25
            for i in range(0, len(groups), chunk_size):
                chunk = groups[i : i + chunk_size]
                await asyncio.gather(
                    *(self.fetch_section_details(group) for group in chunk)
                )

            # fetch books and store in cache
            await self.fetch_books()

            groupUpdates = [group for group in groups if group.get("section")]
            self.process_and_write_updated_groups_chunks(groupUpdates)

            activeGroupIds = [
                {"regGroupSourceId": group.get("regGroupSourceId")} for group in groups
            ]
            self.write_xml_file(activeGroupIds, "activeGroup")

        end_time = time.perf_counter()
        total_runtime = end_time - start_time

        minutes = int(total_runtime // 60)
        seconds = int(total_runtime % 60)

        logging.info(f"Total runtime: {minutes} minutes and {seconds} seconds")


