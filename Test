    async def make_request(self, method, url, data=None):
        """
        Performs a full API request, orchestrating token management,
        resilient retries, and chunked pagination for large datasets.
        """
        headers = {
            "Connection": "keep-alive",
            "Authorization": f"Bearer {await self.get_token()}",
            "x-page-current": "1",
            "x-page-length": "2500",
            "x-custom-entity": X_CUSTOM_ENTITY,
            "Content-Type": "application/json-patch+json",
            "api-version": "3.0",
        }

        # Make the first page request to get the total page count.
        first_page_content, response_headers = await self.fetch_with_exponential_backoff(
            self._send_request, method, url, headers, data
        )

        all_responses = first_page_content
        total_pages = int(response_headers.get("x-page-count", 1))

        # If the response is paginated, fetch subsequent pages in controlled chunks.
        if total_pages > 1:
            # Define the size of each concurrent chunk of requests. 20 is a safe number
            # that aligns with your TCPConnector's connection limit.
            chunk_size = 20
            
            # Loop through the remaining pages in sequential chunks.
            for start_page in range(2, total_pages + 1, chunk_size):
                end_page = min(start_page + chunk_size, total_pages + 1)
                
                tasks = []
                logging.info(f"Fetching page chunk: {start_page} to {end_page - 1} of {total_pages}")

                for page_num in range(start_page, end_page):
                    page_headers = headers.copy()
                    page_headers["x-page-current"] = str(page_num)
                    task = self.fetch_with_exponential_backoff(
                        self._send_request, method, url, page_headers, data
                    )
                    tasks.append(task)
                
                # The 'gather' now only runs for a small chunk of tasks at a time.
                if tasks:
                    page_results = await asyncio.gather(*tasks)
                    for page_content, _ in page_results:
                        all_responses.extend(page_content)

        return all_responses
