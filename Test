# In APIClient class
    async def _send_request(self, method: str, url: str, headers: dict, data: dict = None) -> tuple:
        """
        Sends a single HTTP request and raises an exception for non-2xx responses.
        This function is intended to be wrapped by the exponential backoff logic.
        
        Returns:
            A tuple containing the JSON content and the response headers.
        """
        async with self.session.request(
            method, url, headers=headers, json=data, proxy=self.proxy
        ) as response:
            # This is the crucial step: Raise an exception for bad status codes (4xx or 5xx).
            # This ensures a 502 Bad Gateway immediately becomes a ClientResponseError.
            response.raise_for_status()
            
            # If the status is successful (2xx), proceed to parse the response.
            text_content = await response.text()
            
            # Return headers as well, as they are needed for pagination info.
            return orjson.loads(text_content), response.headers
