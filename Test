    async def _process_updated_groups(self, groups: list):
        """
        Identifies recently updated groups and orchestrates the fetching
        of their section details in concurrent chunks.

        Args:
            groups: The full list of filtered and normalized group objects.
        """
        logging.info("Identifying groups that have been updated since the last run...")
        
        groups_to_process = []
        for group in groups:
            raw_updated_date = group.get("updatedDate")
            if not raw_updated_date:
                continue

            iso_date = raw_updated_date.replace("Z", "+00:00")
            try:
                updated_dt = datetime.fromisoformat(iso_date)
            except ValueError:
                try:
                    updated_dt = datetime.strptime(iso_date[:19], "%Y-%m-%dT%H:%M:%S")
                except ValueError:
                    continue
            
            if updated_dt.tzinfo is None:
                updated_dt = updated_dt.replace(tzinfo=timezone.utc)

            if updated_dt > LAST_RUN:
                groups_to_process.append(group)
        
        if not groups_to_process:
            logging.info("No new group updates require section processing.")
            return

        logging.info(f"Found {len(groups_to_process):,} updated groups. Beginning to fetch their section details...")
        
        chunk_size = 25
        for i in range(0, len(groups_to_process), chunk_size):
            chunk = groups_to_process[i : i + chunk_size]
            await asyncio.gather(
                *(self.fetch_section_details(group) for group in chunk)
            )
