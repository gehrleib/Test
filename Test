    if os.getenv('USE_PROXY', 'False').lower() == 'true':
        proxy_vars = ['PROXY_USERNAME', 'PROXY_PASSWORD', 'PROXY_URL']
        missing_vars.extend([var for var in proxy_vars if not os.getenv(var)])
    
