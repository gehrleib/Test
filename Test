import os
import glob
import xmltodict
import json
import argparse
from datetime import datetime

def get_plural_form(singular: str) -> str:
    """
    Determines the correct plural form for a given word.
    This is the key change to fix the 'issuingBody' issue.
    """
    if singular.endswith('y'):
        # Handles words like 'issuingBody' -> 'issuingBodies'
        return singular[:-1] + 'ies'
    else:
        # Handles words like 'group' -> 'groups'
        return singular + 's'

def find_files(directory: str, file_type: str) -> list:
    """Finds all XML files in a directory that match a given type."""
    pattern = os.path.join(directory, f"{file_type}_*.xml")
    files = glob.glob(pattern)
    if not files:
        print(f"Warning: No files found matching pattern: {pattern}")
    else:
        print(f"Found {len(files)} files to combine for type '{file_type}'.")
    return files

def combine_and_deduplicate_records(file_paths: list, file_type: str) -> list:
    """
    Parses multiple XML files, combines their records, and removes duplicates.
    """
    all_records = []
    # Use the new helper function to get the correct plural root element name.
    root_element_name = get_plural_form(file_type)
    
    for file_path in file_paths:
        try:
            with open(file_path, 'r', encoding='utf-8') as f:
                data = xmltodict.parse(f.read())
                # Navigate to the list of records using the correct root name.
                records = data.get(root_element_name, {}).get(file_type, [])
                if records:
                    # If there's only one record, xmltodict doesn't create a list.
                    # This ensures it's always treated as a list.
                    if not isinstance(records, list):
                        records = [records]
                    all_records.extend(records)
        except Exception as e:
            print(f"Error processing file {file_path}: {e}")
            continue

    if not all_records:
        return []

    # Deduplicate records by creating a unique signature for each one.
    unique_records_set = set()
    unique_records_list = []
    for record in all_records:
        record_signature = json.dumps(record, sort_keys=True)
        if record_signature not in unique_records_set:
            unique_records_set.add(record_signature)
            unique_records_list.append(record)
            
    return unique_records_list

def write_combined_xml(records: list, file_type: str, output_directory: str):
    """Writes the final list of unique records to a new combined XML file."""
    if not records:
        print("No unique records found to write.")
        return

    # Use the helper function again for the final output file.
    root_container_name = get_plural_form(file_type)
    
    xml_data_structure = {
        root_container_name: {
            file_type: records,
            "@count": str(len(records)),
        }
    }

    output_file_name = f"{file_type}_combined_{datetime.now().strftime('%Y%m%d_%H%M%S')}.xml"
    output_path = os.path.join(output_directory, output_file_name)

    try:
        xml_string = xmltodict.unparse(
            xml_data_structure,
            pretty=True,
            indent=" " * 4,
            full_document=True,
        )
        with open(output_path, "w", encoding="utf-8") as outfile:
            outfile.write(xml_string)
        print(f"Successfully created combined file: {output_path}")
    except Exception as e:
        print(f"Error writing combined XML file: {e}")

if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description="Combine multiple XML files of the same type and remove duplicate records."
    )
    parser.add_argument("directory", help="The directory containing the XML files (e.g., './output').")
    parser.add_argument("file_type", help="The base name of the files to combine (e.g., 'group', 'issuingBody').")
    
    args = parser.parse_args()

    xml_files = find_files(args.directory, args.file_type)
    if xml_files:
        unique_records = combine_and_deduplicate_records(xml_files, args.file_type)
        print(f"Total unique records found: {len(unique_records):,}")
        write_combined_xml(unique_records, args.file_type, args.directory)
    else:
        print("No files to process.")
