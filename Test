    async def fetch_groups(self) -> list:
        """
        Fetches all group records from the API with a stable sort order
        to prevent pagination drift, and logs diagnostic counts.
        """
        logging.info("Beginning to fetch group data...")

        # NOTE: The 'sort' parameter syntax is an example. You must confirm
        # the correct parameter name and value format from the API documentation.
        request_data = {
            "status": "publish",
            "regGroups": [
                {"sourceId": "d5b079cf-5041-49b9-8183-5e2da221a343"},
                {"sourceId": "2af8f5c4-b8c8-4716-94eb-a20ad52a5c9d"},
                {"sourceId": "2926ead6-0a9a-4b6b-81a8-af5560f3cee0"},
                {"sourceId": "d9eef6f7-9f33-4247-9d3f-947942857380"},
                {"sourceId": "3a8bbe26-54fa-4615-8aaa-a8dbe1231259"},
                {"sourceId": "6d7964c6-26b2-43c5-b474-dc84440a32df"},
            ],
            "sort": "createDate,regGroupSourceId" # Example of a stable, multi-level sort
        }

        # The make_request call will handle pagination and retries.
        groups = await self.make_request(
            "POST",
            f"{API_CONNECT_URL}/api/RegGroup/search",
            data=request_data,
        )
        
        # --- Diagnostic Count Logging ---
        total_records_received = len(groups)
        
        # Calculate the number of unique groups by creating a set of their IDs.
        unique_group_ids = {group.get("regGroupSourceId") for group in groups}
        total_unique_records = len(unique_group_ids)
        
        logging.info(f"Fetch complete. Received {total_records_received:,} total records, with {total_unique_records:,} unique group IDs.")
        
        # Log a warning if duplicate records were received, which indicates a pagination issue.
        if total_records_received > total_unique_records:
            duplicate_count = total_records_received - total_unique_records
            logging.warning(f"Detected {duplicate_count:,} duplicate group records in the paginated response.")

        return groups
