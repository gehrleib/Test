<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="3.0"
  xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
  xmlns:xs="http://www.w3.org/2001/XMLSchema"
  exclude-result-prefixes="xs">

  <xsl:output method="xml" indent="yes" />

  <xsl:template match="/">
    <ArcherRecords>
      <xsl:for-each select="Records/Record">
        <xsl:variable name="currentChange">
          <xsl:value-of select="string-join(Field[@guid='0582f91a-551d-42b5-9d43-ab39738d3278']/ListValues/ListValue/@displayName, '')" />
        </xsl:variable>
        
        <xsl:variable name="date1">
          <xsl:value-of select="Field[@guid='34e15bb7-0851-4897-af40-106517096264']/@xmlConvertedValue" />
        </xsl:variable>

        <xsl:variable name="updatedChange">
          <xsl:for-each select="Record/Field[@guid='2244a286-7022-406d-9c88-a87186f5477e']">
            <xsl:variable name="date2">
              <xsl:value-of select="@xmlConvertedValue" />
            </xsl:variable>
            <xsl:if test="xs:dateTime($date2) &gt; xs:dateTime($date1)">
              <xsl:value-of select="../Field[@guid='04be04de-697b-4d6c-b264-de5da562ea21']/ListValues/ListValue/@displayName" />
            </xsl:if>
          </xsl:for-each>
        </xsl:variable>

        <xsl:if test="not($currentChange = $updatedChange)">
          <ArcherRecord>
            <Tracking_ID>
              <xsl:value-of select="@contentId" />
            </Tracking_ID>
            
            <!-- Tokenize and loop through each change -->
            <xsl:variable name="tokens" select="tokenize($updatedChange, '0')" /> <!-- Look for the first digit -->
            
            <xsl:for-each select="$tokens">
              <xsl:if test=". != ''"> <!-- Ignore any empty tokens -->
                <Material_Change>
                  <xsl:value-of select="concat(0, normalize-space(.))" />
                </Material_Change>
              </xsl:if>
            </xsl:for-each>
            
          </ArcherRecord>
        </xsl:if>
      </xsl:for-each>
    </ArcherRecords>
  </xsl:template>

</xsl:stylesheet>
