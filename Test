# In CUBE.py, at the top level of the script

def load_and_validate_env_vars():
    """
    Loads environment variables and validates that all required variables are set.

    This function implements a "Fail-Fast" strategy. If any critical
    configuration is missing, it logs a critical error and immediately
    terminates the script to prevent runtime errors.
    """
    load_dotenv(ENV_FILE)
    
    # Define all configuration variables essential for the script to run.
    required_vars = [
        "API_ID_URL",
        "API_CONNECT_URL",
        "USER",
        "PASSWORD",
        "SCOPE",
        "CLIENT_ID",
        "CLIENT_SECRET",
        "X_CUSTOM_ENTITY",
    ]

    # Conditionally require proxy variables only if USE_PROXY is enabled.
    if os.getenv("USE_PROXY", "False").lower() == "true":
        proxy_vars = ["PROXY_USERNAME", "PROXY_PASSWORD", "PROXY_URL"]
        required_vars.extend(proxy_vars)

    # Identify any required variables that are missing or empty.
    missing_vars = [var for var in required_vars if not os.getenv(var)]

    if missing_vars:
        error_message = f"Critical configuration error. Missing required environment variables: {', '.join(missing_vars)}"
        logging.critical(error_message)
        sys.exit(error_message)

# --- Immediately execute the validation function upon script startup ---
load_and_validate_env_vars()


# --- Global Variable Definitions ---
# Because validation passed, these variables can be loaded with confidence
# that they are not None, satisfying static analysis and preventing runtime errors.

USE_PROXY: bool = os.getenv("USE_PROXY", "False").lower() == "true"
PROXY_USERNAME: str = os.getenv("PROXY_USERNAME")
PROXY_PASSWORD: str = os.getenv("PROXY_PASSWORD")
PROXY_URL: str = os.getenv("PROXY_URL")
API_ID_URL: str = os.getenv("API_ID_URL")
API_CONNECT_URL: str = os.getenv("API_CONNECT_URL")
X_CUSTOM_ENTITY: str = os.getenv("X_CUSTOM_ENTITY")
TOKEN_REFRESH_THRESHOLD: int = 300

# LAST_RUN has a safe default and is not considered a critical failure if missing.
LAST_RUN: datetime = datetime.fromisoformat(os.getenv("LAST_RUN") or "1970-01-01T00:00:00+00:00")
