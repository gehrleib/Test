def update_last_run():
    """
    Update the LAST_RUN environment variable with the current timestamp.

    The timestamp is written to the .env file in ISO 8601 format.
    """
    last_run = (
        datetime.now(timezone.utc)
        .replace(hour=0, minute=0, second=0, microsecond=0)
        .isoformat(timespec="milliseconds")
    )
    lines = open(ENV_FILE).read().splitlines()
    with open(ENV_FILE, "w") as f:
        for line in lines:
            if line.startswith("LAST_RUN"):
                f.write(f"LAST_RUN = {last_run}\n")
            else:
                f.write(line + "\n")
        if not any(l.startswith("LAST_RUN") for l in lines):
            f.write(f"LAST_RUN = {last_run}\n")


class APIClient:
    def __init__(self):
        self.token = None
        self.token_expiration = None

        self.proxy = self.get_proxy()
        self.session = None

        self.book_cache = {}

    def get_proxy(self) -> str:
        """
        Construct the proxy URL if proxy settings are enabled.

        Returns:
            str: The proxy URL, or None if proxies are not used.
        """
        if USE_PROXY:
            proxy_url_to_log = (
                f"http://{PROXY_USERNAME}:***@{PROXY_URL}"  # Mask password in log
            )
            logging.info(f"Proxy is enabled. Using proxy: {proxy_url_to_log}")
            return f"http://{PROXY_USERNAME}:{PROXY_PASSWORD}@{PROXY_URL}"
        else:
            logging.info("Proxy is not enabled.")
            return None

    async def get_token(self) -> str:
        """
        Retrieve an authentication token asynchronously, refreshing it if necessary.

        Returns:
            str: The access token.
        """
        if (
            self.token
            and self.token_expiration
            and time.time() < self.token_expiration - TOKEN_REFRESH_THRESHOLD
        ):
            return self.token

        url = f"{API_ID_URL}/connect/token"
        headers = {"Content-Type": "application/x-www-form-urlencoded"}
        data = {
            "grant_type": "password",
            "username": os.getenv("USER"),
            "password": os.getenv("PASSWORD"),
            "scope": os.getenv("SCOPE"),
            "client_id": os.getenv("CLIENT_ID"),
            "client_secret": os.getenv("CLIENT_SECRET"),
        }

        async with self.session.post(
            url, data=data, headers=headers, proxy=self.proxy
        ) as response:
            response.raise_for_status()
            text_content = await response.text()
            token_data = orjson.loads(text_content)
            self.token = token_data["access_token"]
            self.token_expiration = time.time() + token_data["expires_in"]
            return self.token

    async def fetch_with_exponential_backoff(self, func, max_retries=5, base_delay=1):
        """
        Retry a function with exponential backoff for handling transient errors.

        Args:
            func (Callable): The function to retry.
            max_retries (int): The maximum number of retry attempts.
            base_delay (int): The base delay in seconds before retrying.

        Returns:
            Any: The result of the function.
        """
        for retry in range(max_retries):
            try:
                return await func()
            except aiohttp.ClientError as e:  # Catch base ClientError
                # Check for the specific 404 ClientResponseError case first
                if isinstance(e, aiohttp.ClientResponseError) and e.status == 404:
                    url_info = e.request_info.url if e.request_info else "Unknown URL"
                    logging.warning(
                        f"Request to {url_info} resulted in a 404 Not Found. This specific error will not be retried."
                    )
                    raise  # Re-raise to be caught by the caller

                # Common retry logic for all other ClientErrors (including other ClientResponseErrors)
                if retry == max_retries - 1:
                    error_type_name = type(e).__name__
                    status_code = (
                        f" (status: {e.status})"
                        if isinstance(e, aiohttp.ClientResponseError)
                        else ""
                    )
                    logging.error(
                        f"Max retries reached for {error_type_name}{status_code}. Giving up. Error: {e}"
                    )
                    raise

                delay = base_delay * (2**retry) + random.uniform(0, 1)

                log_message_prefix = (
                    f"Retry {retry + 1}/{max_retries} after {delay:.2f} seconds due to"
                )
                if isinstance(e, aiohttp.ClientResponseError):
                    logging.warning(
                        f"{log_message_prefix} ClientResponseError ({e.status}): {e}"
                    )
                else:
                    logging.warning(f"{log_message_prefix} {type(e).__name__}: {e}")

                await asyncio.sleep(delay)

    async def make_request(self, method, url, data=None):
        """
        Perform an HTTP request asynchronously, handling token refresh and retries.

        Args:
            method (str): HTTP method (e.g., 'GET', 'POST').
            url (str): The URL for the request.
            data (dict, optional): The data to send with the request.

        Returns:
            dict: The response data.
        """
        headers = {
            "Connection": "keep-alive",
            "Authorization": f"Bearer {await self.get_token()}",
            "x-page-current": "1",
            "x-page-length": "2500",
            "x-custom-entity": X_CUSTOM_ENTITY,
            "Content-Type": "application/json-patch+json",
            "api-version": "3.0",
        }

        async def _make_request():
            try:
                async with self.session.request(
                    method, url, headers=headers, json=data, proxy=self.proxy
                ) as response:
                    # Handle 500 Internal Server Error by refreshing token and retrying
                    if response.status == 500:
                        headers["Authorization"] = f"Bearer {await self.get_token()}"
                        async with self.session.request(
                            method, url, headers=headers, json=data, proxy=self.proxy
                        ) as retry_response:
                            retry_response.raise_for_status()
                            text_content_retry = await retry_response.text()
                            return orjson.loads(text_content_retry)

                    response.raise_for_status()

                    # Handle pagination if applicable
                    text_content_main = await response.text()
                    all_responses = orjson.loads(text_content_main)

                    total_pages = int(response.headers.get("x-page-count", 1))
                    if total_pages > 1:
                        tasks = [
                            self.fetch_page(headers, page, url, data, method)
                            for page in range(2, total_pages + 1)
                        ]
                        page_results = await asyncio.gather(*tasks)
                        all_responses.extend(
                            item for sublist in page_results for item in sublist
                        )

                    return all_responses

            except CancelledError:
                logging.info("Request task was cancelled.")
            except aiohttp.ClientError as e:
                raise  # Re-raise for fetch_with_exponential_backoff to handle

        return await self.fetch_with_exponential_backoff(_make_request)

    async def fetch_page(
        self, headers: dict, page: int, url: str, data: dict, method: str
    ) -> dict:
        """
        Fetch a single page of results for a paginated request.

        Args:
            headers (dict): The request headers.
            page (int): The page number to fetch.
            url (str): The URL for the request.
            data (dict): The data to send with the request.
            method (str): HTTP method (e.g., 'GET', 'POST').

        Returns:
            dict: The response data for the page.
        """
        headers["x-page-current"] = str(page)
        async with self.session.request(
            method, url, headers=headers, json=data, proxy=self.proxy
        ) as page_response:
            text_content_page = await page_response.text()  # New
            return orjson.loads(text_content_page)

