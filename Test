import argparse
from typing import Set, Tuple

def parse_log_file(file_path: str) -> Tuple[Set[str], int, int]:
    """
    Parses a log file to extract unique Group IDs from 'Skipping' log lines.

    This version uses a simple and robust string-splitting method instead of
    a complex regular expression to guarantee matches.

    Args:
        file_path: The path to the log file.

    Returns:
        A tuple containing:
        - A set of unique Group ID strings.
        - The total number of lines read.
        - The number of lines that contained the key phrase.
    """
    # This is the key phrase we will use to find and split the line.
    key_phrase = "Skipping Group ID"
    skipped_ids = set()
    lines_read = 0
    lines_matched = 0

    try:
        with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:
            for line in f:
                lines_read += 1
                
                # Use a simple 'in' check, which is more reliable than regex here.
                # We also check case-insensitively.
                if key_phrase.lower() in line.lower():
                    lines_matched += 1
                    try:
                        # Split the line at our key phrase to isolate the part after it.
                        # We take the second part [1] of the split result.
                        post_part = line.split(key_phrase, 1)[1]
                        
                        # The ID is between the start of this new string and the first colon.
                        group_id = post_part.split(':', 1)[0]
                        
                        # Clean up any leading/trailing whitespace and add to our set.
                        skipped_ids.add(group_id.strip())
                    except IndexError:
                        # This will happen if the line contains the key phrase but has an
                        # unexpected format. We can simply ignore these lines.
                        continue
                        
    except FileNotFoundError:
        print(f"Error: The file '{file_path}' was not found.")
        exit(1)
        
    return skipped_ids, lines_read, lines_matched

def compare_logs(file1_path: str, file2_path: str):
    """Compares two log files to find differences in skipped Group IDs."""
    print(f"Comparing log files:\n- Old Log: {file1_path}\n- New Log: {file2_path}\n")

    ids_from_file1, read1, matched1 = parse_log_file(file1_path)
    ids_from_file2, read2, matched2 = parse_log_file(file2_path)

    # --- Diagnostic Output ---
    print("--- Diagnostics ---")
    print(f"File 1 ('{file1_path}'):")
    print(f"  - Total lines read:       {read1:,}")
    print(f"  - Lines with key phrase:  {matched1:,}")
    print(f"  - Unique skipped IDs found: {len(ids_from_file1):,}")
    print()
    print(f"File 2 ('{file2_path}'):")
    print(f"  - Total lines read:       {read2:,}")
    print(f"  - Lines with key phrase:  {matched2:,}")
    print(f"  - Unique skipped IDs found: {len(ids_from_file2):,}")
    print("-" * 20)
    # --- End of Diagnostics ---

    removed_ids = ids_from_file1 - ids_from_file2
    added_ids = ids_from_file2 - ids_from_file1

    if not removed_ids and not added_ids:
        print("\n✅ No differences found. The set of skipped groups is identical.")
        if matched1 == 0 and matched2 == 0:
            print("   Warning: The phrase 'Skipping Group ID' was not found in either file.")
    else:
        if added_ids:
            print(f"\n➕ Groups ADDED to the skip list in the new log ({len(added_ids):,})")
            for group_id in sorted(list(added_ids)):
                print(f"  - {group_id}")
            print()
        if removed_ids:
            print(f"\n➖ Groups REMOVED from the skip list in the new log ({len(removed_ids):,})")
            for group_id in sorted(list(removed_ids)):
                print(f"  - {group_id}")
            print()

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Compare two application logs to find differences in skipped Group IDs.")
    parser.add_argument("old_log", help="The path to the first or older log file.")
    parser.add_argument("new_log", help="The path to the second or newer log file.")
    
    args = parser.parse_args()
    compare_logs(args.old_log, args.new_log)
