<xsl:stylesheet version="2.0"
                xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
                xmlns:xs="http://www.w3.org/2001/XMLSchema"
                exclude-result-prefixes="xs">

    <xsl:output method="xml" indent="yes" encoding="UTF-8"/>
    <xsl:strip-space elements="*"/>

    <xsl:key name="fieldDefByGuid" match="FieldDefinition" use="@guid"/>

    <xsl:variable name="groupLevelGuid" select="'52008dc4-e437-4dc7-a73f-d3e04e4c740a'"/>
    <xsl:variable name="validationLevelGuid" select="'28b4b409-6ae0-40f5-965a-c117b8ad87cd'"/>
    <xsl:variable name="groupPublishDateGuid" select="'dff6a5bc-5333-48bc-b6b9-0ea383a8fca7'"/>
    <xsl:variable name="reviewDateGuid" select="'a12bde54-8b48-4b5b-89a6-dbd76be9876c'"/>
    <xsl:variable name="regulatoryThemeGuid" select="'2f6271ce-487a-4f8f-8704-335594f34bd7'"/>
    <xsl:variable name="appliesRbcGuid" select="'34417574-208c-4c59-b9c8-27ab93ed6274'"/>
    <xsl:variable name="imposesRbcGuid" select="'87351d76-76d1-4787-9d01-3f7a38bbc9d3'"/>
    <xsl:variable name="themeTypeGuid" select="'f40909d0-fd68-4fdc-8f11-80fae0cf7d8b'"/>
    
    <xsl:variable name="overallStatusGuidPlaceholder" select="'overall-status-guid-placeholder'"/> 
    <xsl:variable name="terminalStatuses" select="('Approved', 'Rejected')"/>
    <xsl:variable name="approvedStatus" select="'Approved'"/>

    <xsl:template match="/Records">
        <ArcherRecords>
            <xsl:apply-templates select="Record[@levelGuid=$groupLevelGuid]"/>
        </ArcherRecords>
    </xsl:template>

    <xsl:template match="Record[@levelGuid=$groupLevelGuid]">
        <xsl:variable name="currentGroup" select="."/>
        <xsl:variable name="allValidationRecords" select="$currentGroup/Record[@levelGuid=$validationLevelGuid]"/>

        <xsl:if test="exists($allValidationRecords)">
            
            <xsl:variable name="allVPsInTerminalState"
                select="every $vr in $allValidationRecords satisfies
                            ($vr/Field[@guid=$overallStatusGuidPlaceholder]/ListValues/ListValue/@displayName = $terminalStatuses)"/>

            <xsl:if test="$allVPsInTerminalState">
                <xsl:variable name="approvedVPsWithReviewDate"
                    select="$allValidationRecords
                                [Field[@guid=$overallStatusGuidPlaceholder]/ListValues/ListValue/@displayName = $approvedStatus]
                                [Field[@guid=$reviewDateGuid and normalize-space(@xmlConvertedValue) != '']]"/>

                <xsl:if test="exists($approvedVPsWithReviewDate)">
                    
                    <xsl:variable name="reviewDatesFromEligibleVPs"
                        select="$approvedVPsWithReviewDate/Field[@guid=$reviewDateGuid]/@xmlConvertedValue/xs:dateTime(.)"/>
                    
                    <xsl:if test="exists($reviewDatesFromEligibleVPs)">
                        <xsl:variable name="maxReviewDateFromEligible" select="max($reviewDatesFromEligibleVPs)"/>
                        <xsl:variable name="chosenValidationRecord"
                            select="($approvedVPsWithReviewDate
                                        [xs:dateTime(Field[@guid=$reviewDateGuid]/@xmlConvertedValue) = $maxReviewDateFromEligible])[1]"/>
                        <xsl:variable name="chosenReviewDate" select="$maxReviewDateFromEligible"/>

                        <xsl:variable name="groupPublishDateField" select="$currentGroup/Field[@guid=$groupPublishDateGuid and normalize-space(@xmlConvertedValue) != '']"/>
                        <xsl:if test="$groupPublishDateField">
                            <xsl:variable name="groupPublishDate" select="xs:dateTime($groupPublishDateField/@xmlConvertedValue)"/>
                            <xsl:if test="$groupPublishDate > $chosenReviewDate">
                                <xsl:call-template name="CreateArcherRecord">
                                    <xsl:with-param name="groupContentId" select="$currentGroup/@contentId"/>
                                    <xsl:with-param name="validationRecordNode" select="$chosenValidationRecord"/>
                                </xsl:call-template>
                            </xsl:if>
                        </xsl:if>
                    </xsl:if>
                </xsl:if>
            </xsl:if>
        </xsl:if>
    </xsl:template>

    <xsl:template name="CreateArcherRecord">
        <xsl:param name="groupContentId"/>
        <xsl:param name="validationRecordNode"/>

        <xsl:variable name="appliesIsYes" as="xs:boolean"
            select="$validationRecordNode/Field[@guid=$appliesRbcGuid]/ListValues/ListValue/@displayName = 'Yes'"/>
        <xsl:variable name="imposesIsYes" as="xs:boolean"
            select="$validationRecordNode/Field[@guid=$imposesRbcGuid]/ListValues/ListValue/@displayName = 'Yes'"/>
        <xsl:variable name="themeTypeContainsConduct" as="xs:boolean"
            select="exists($validationRecordNode/Field[@guid=$themeTypeGuid]/ListValues/ListValue[contains(@displayName, 'Conduct')])"/>
        
        <xsl:variable name="potentialChangeValue" as="xs:string">
            <xsl:choose>
                <xsl:when test="$appliesIsYes and $imposesIsYes and $themeTypeContainsConduct">
                    <xsl:text>Yes</xsl:text>
                </when>
                <xsl:otherwise>
                    <xsl:text>No</xsl:text>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>

        <ArcherRecord>
            <Group_ContentID>
                <xsl:value-of select="$groupContentId"/>
            </Group_ContentID>
            
            <Potential_Change_in_Content>
                <xsl:value-of select="$potentialChangeValue"/>
            </Potential_Change_in_Content>
            
            <xsl:apply-templates select="$validationRecordNode/Field"/>
        </ArcherRecord>
    </xsl:template>

    <xsl:template match="Field">
        <xsl:variable name="fieldGuid" select="@guid"/>
        <xsl:variable name="fieldDefinitionNode" select="key('fieldDefByGuid', $fieldGuid)"/>

        <xsl:if test="$fieldDefinitionNode">
            <xsl:variable name="fieldAlias" select="$fieldDefinitionNode/@alias"/>
            <xsl:element name="{$fieldAlias}">
                <xsl:choose>
                    <xsl:when test="$fieldGuid = $regulatoryThemeGuid">
                        <xsl:for-each select="Reference">
                            <Item>
                                <xsl:value-of select="normalize-space(.)"/>
                            </Item>
                        </xsl:for-each>
                    </xsl:when>
                    <xsl:when test="$fieldGuid = $themeTypeGuid">
                        <xsl:for-each select="ListValues/ListValue">
                            <Item>
                                <xsl:value-of select="@displayName"/>
                            </Item>
                        </xsl:for-each>
                    </xsl:when>
                    <xsl:when test="ListValues/ListValue">
                        <xsl:value-of select="ListValues/ListValue[1]/@displayName"/>
                    </xsl:when>
                    <xsl:when test="Reference">
                        <xsl:value-of select="normalize-space(Reference[1])"/>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="."/>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:element>
        </xsl:if>
    </xsl:template>

</xsl:stylesheet>
