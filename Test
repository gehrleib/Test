# In APIClient class in CUBE.py

    async def get_token(self, force_refresh: bool = False) -> str:
        """
        Retrieves a valid authentication token, using a "double-checked locking"
        pattern to prevent race conditions from multiple concurrent requests.
        """
        # First, check if the token is valid without acquiring the lock.
        # This is a fast path for the majority of calls that do not need a refresh.
        if not force_refresh and self.token and self.token_expiration and \
           time.time() < self.token_expiration - TOKEN_REFRESH_THRESHOLD:
            return self.token

        # If a refresh is needed, acquire the lock to ensure only one task proceeds.
        async with self._token_lock:
            # --- The Critical Second Check ---
            # After acquiring the lock, we RE-CHECK the token's validity.
            # This solves the race condition: if another task just refreshed the
            # token while this task was waiting, this check will pass, and we
            # will return the new token instantly without another API call,
            # even if this task was originally called with force_refresh=True.
            if self.token and self.token_expiration and \
               time.time() < self.token_expiration - TOKEN_REFRESH_THRESHOLD:
                return self.token

            # If we are here, we are the only task holding the lock while the
            # token is expired, so we must fetch a new one.
            if self.session is None:
                raise RuntimeError("ClientSession not initialized.")

            logging.info("Fetching new API token...")
            url = f"{API_ID_URL}/connect/token"
            headers = {"Content-Type": "application/x-www-form-urlencoded"}
            data = {
                "grant_type": "password",
                "username": os.getenv("USER"),
                "password": os.getenv("PASSWORD"),
                "scope": os.getenv("SCOPE"),
                "client_id": os.getenv("CLIENT_ID"),
                "client_secret": os.getenv("CLIENT_SECRET"),
            }

            async with self.session.post(url, data=data, headers=headers, proxy=self.proxy) as response:
                response.raise_for_status()
                text_content = await response.text()
                token_data = orjson.loads(text_content)

                self.token = token_data["access_token"]
                self.token_expiration = time.time() + token_data["expires_in"]
                
                logging.info("Successfully fetched new API token.")
                return self.token
