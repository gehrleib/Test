def get_executable_path():
    """Gets the absolute path to the executable.

    Returns:
        str: The absolute path to the executable, or None if it cannot be determined.
    """
    try:
        executable_path = sys.executable

        # Check if it's a frozen executable (created by tools like py2exe, cx_Freeze)
        if getattr(sys, "frozen", False):  # Check for frozen attribute
            executable_path = (
                sys.executable
            )  # In frozen executables, sys.executable is the exe path
        else:  # Normal Python script execution.
            executable_path = os.path.abspath(sys.argv[0])  # Path of the script
            if os.path.isdir(
                executable_path
            ):  # If it's a directory, it means we ran python on that directory
                executable_path = os.path.join(executable_path, "__main__.py")
            elif not os.path.exists(
                executable_path
            ):  # The script might have been called with python -m module
                import importlib.util

                spec = importlib.util.find_spec(sys.argv[0])
                if spec:
                    executable_path = spec.origin
                else:
                    return None  # Could not find the path

        return executable_path
    except Exception as e:
        logging.error(f"Error getting executable path: {e}")
        return None


