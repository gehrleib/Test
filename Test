    def process_and_write_group_chunks(self, groups, output_directory="output", chunk_size=100, indent=4):
        issuing_bodies = {}
        issuances = {}

        # Process groups and extract data for the three files
        for group in groups:
            book_data = group.pop("book", None)
            if book_data:
                issuing_body_source_id = book_data.get("issuingBodySourceId")
                if issuing_body_source_id:
                    issuing_bodies[issuing_body_source_id] = {
                        "issuingBodySourceId": issuing_body_source_id,
                        "issuingBodyName": book_data["issuingBodyName"]
                    }

                issuance_source_id = book_data.get("sourceId")
                if issuance_source_id:
                    issuance_data = {
                        "issuanceSourceId": issuance_source_id,
                        **{
                            key: value
                            for key, value in book_data.items()
                            if key not in ["issuingBodyName", "sourceId"]
                        }
                    }
                    issuances[issuance_source_id] = issuance_data

            # Ensure issuanceId is included in the group data
            if "issuanceId" not in group and book_data:
                group["issuanceId"] = issuance_source_id

        # Convert dictionaries to lists
        issuing_bodies = list(issuing_bodies.values())
        issuances = list(issuances.values())

        # Create the output directory if it doesn't exist
        os.makedirs(output_directory, exist_ok=True)

        # Generate a timestamp for filenames
        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')

        # Write each data list to its own XML file within the output directory
        for data, filename_prefix in [
            (issuing_bodies, "issuingBody"),
            (issuances, "issuance"),
            (groups, "group"),
        ]:
            output_file = os.path.join(output_directory, f"{filename_prefix}_{timestamp}.xml")
            temp_file = output_file + ".tmp"
            root_element = filename_prefix  # Use the prefix as root element name

            try:
                with open(temp_file, 'w', encoding='utf-8') as outfile:
                    outfile.write('<?xml version="1.0" encoding="utf-8"?>\n')
                    outfile.write(f'<{root_element}s count="{len(data)}">\n')  # Use pluralized root element

                    # Process and write data in chunks
                    for i in range(0, len(data), chunk_size):
                        chunk = data[i:i + chunk_size]

                        for item in chunk:
                            item_xml = xmltodict.unparse({root_element: item}, pretty=True)
                            item_xml = item_xml.replace('<?xml version="1.0" encoding="utf-8"?>', '').strip()

                            # Ensure proper indentation
                            item_xml = item_xml.strip()
                            lines = item_xml.split('\n')
                            indented_lines = [lines[0]]
                            for line in lines[1:]:
                                indented_lines.append(' ' * indent + line)
                            indented_item_xml = '\n'.join(indented_lines)

                            outfile.write(f'{" " * indent}{indented_item_xml}\n') 

                    outfile.write(f'</{root_element}s>')

                shutil.move(temp_file, output_file)
                logging.info(f"Data successfully written to {output_file}")

            except IOError as e:
                logging.error(f"Error writing to file: {e}")
                if os.path.exists(temp_file):
                    os.remove(temp_file)

            except Exception as e:
                logging.error(f"An unexpected error occurred: {e}")
                if os.path.exists(temp_file):
                    os.remove(temp_file)

    async def run(self):
        
        start_time = time.perf_counter()

        logging.info(f"Total runtime for processing groups: {datetime.now()}")

        async with aiohttp.ClientSession() as self.session:
            
            # Perform the initial API request to get the groups;;
            groups = await self.make_request(
                'POST',
                API_CONNECT_URL + '/api/RegGroup/search',
                data={
                    "status": "publish",
                    "regGroups": [
                        {"sourceId": "2af8f5c4-b8c8-4716-94eb-a20ad52a5c9d"},
                    ]
                }
            )

            chunk_size = 50

            i = 0  # Track the starting index for the next chunk
            while i < len(groups):
                try:
                    chunk = groups[i:i + chunk_size]
                    await asyncio.gather(*(self.process_group(group) for group in chunk))
                    i += chunk_size  # Move to the next chunk if the current chunk is successful

                except asyncio.CancelledError:
                    print(f"CancelledError occurred, restarting from chunk starting at index {i}")
                    await asyncio.sleep(2)  # Wait before retrying (optional)
                    # The loop will retry from the current index 'i' due to the while loop structure

            # Remove any groups that are "Archived" or have been cleared in process_group
            filtered_groups = [group for group in groups if group]

            self.process_and_write_group_chunks(filtered_groups)

            end_time = time.perf_counter()  # Record the end time
            total_runtime = end_time - start_time

            minutes = int(total_runtime // 60)  # Calculate minutes
            seconds = int(total_runtime % 60)  # Calculate remaining seconds

            logging.info(f"Total runtime for processing groups: {minutes} minutes and {seconds} seconds")

