# ---------------------------------
# API Endpoint Configuration
# ---------------------------------
# The base URL for the authentication server
API_ID_URL=https://your-api-auth-server.com
# The base URL for the main connect server
API_CONNECT_URL=https://your-api-connect-server.com

# ---------------------------------
# Credentials and Authentication
# ---------------------------------
USER=your_username
PASSWORD=your_secret_password
SCOPE=api_scope
CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret

# ---------------------------------
# Application-Specific Settings
# ---------------------------------
# The custom entity identifier required by the API
X_CUSTOM_ENTITY=your_custom_entity_value
# The number of records to fetch per paginated request
PAGE_LENGTH=2500

# ---------------------------------
# Script State Management
# ---------------------------------
# The timestamp of the last successful script execution.
# This value is managed automatically by the script. On the very first run,
# you can leave it blank or use the provided default.
# Format: YYYY-MM-DDTHH:MM:SS.sss+HH:MM (ISO 8601)
LAST_RUN=1970-01-01T00:00:00+00:00

# ---------------------------------
# Optional Proxy Configuration
# ---------------------------------
# Set to 'true' to enable the proxy, or 'false' to disable it.
USE_PROXY=false
# The following are only required if USE_PROXY is set to 'true'
PROXY_USERNAME=your_proxy_username
PROXY_PASSWORD=your_proxy_password
PROXY_URL=proxy.server.com:8080
