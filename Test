<xsl:stylesheet version="3.0"
    xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
    xmlns:xs="http://www.w3.org/2001/XMLSchema"
    xmlns:map="http://www.w3.org/2005/xpath-functions/map"
    exclude-result-prefixes="xs map">

    <xsl:output method="xml" indent="yes"/>
    <xsl:strip-space elements="*"/>

    <xsl:variable name="gMaterialChanges" select="'3b9f9f1b-7987-48b0-b9a1-3f7b33ddb6f2'"/>
    <xsl:variable name="gSegments"        select="'f5ca444b-fad0-4742-abbb-1873c5a04ff8'"/>
    <xsl:variable name="gAUPrimary"       select="'1c0bbb5b-b2da-4ad7-9498-bc7243fa3e81'"/>
    <xsl:variable name="gAUCrossBorder"   select="'2e4c1012-9670-410d-a6a1-0746b458e0d4'"/>

    <xsl:variable name="gDateOfChange"    select="'2244a286-7022-406d-9c88-a87186f5477e'"/>
    <xsl:variable name="gUpdatedValue"    select="'1f0b84f4-3a6c-49fb-9c6e-7927fca10eaa'"/>

    <xsl:variable name="gAssessableUnitRecord" select="'e1b271d7-fc99-4626-b2b0-ded2a3fcdcfb'"/>
    <xsl:variable name="gAssessableUnitName"   select="'c48f85ab-2e91-4912-b4b5-e1b9432c0f27'"/>
    <xsl:variable name="gSegmentForAU"         select="'569842b8-ad66-479f-8f50-a78cac8f20a2'"/>

    <xsl:template match="/Records">
        <ArcherRecords>
            <xsl:for-each select="Record[not(@parentId > 0)]">
                <xsl:variable name="current-record" select="."/>

                <xsl:variable name="au-segment-map" as="map(xs:string, xs:string)">
                    <xsl:map>
                        <xsl:for-each select="$current-record/Record[@levelGuid = $gAssessableUnitRecord]">
                            <xsl:map-entry key="@contentId" select="Field[@guid = $gSegmentForAU]/ListValues/ListValue/string()"/>
                        </xsl:for-each>
                    </xsl:map>
                </xsl:variable>

                <xsl:variable name="latest-change" as="element()?" select="(
                    <xsl:perform-sort select='$current-record/Field[@guid = $gMaterialChanges]/Subform'>
                        <xsl:sort select='Field[@guid = $gDateOfChange]/@xmlConvertedValue' order='descending' data-type='text'/>
                    </xsl:perform-sort>
                )[1]"/>

                <xsl:variable name="previous-value-for-comparison" select="if ($latest-change) then normalize-space(replace($latest-change/Field[@guid = $gUpdatedValue], '&lt;br&gt;&lt;br&gt;', ', ')) else ''"/>
                <xsl:variable name="previous-tokens" select="sort(tokenize($previous-value-for-comparison, ',\s*'))[normalize-space()]"/>
                <xsl:variable name="updated-tokens" select="sort($current-record/Field[@guid = $gSegments]/Reference/string())[normalize-space()]"/>

                <xsl:if test="not(deep-equal($previous-tokens, $updated-tokens))">
                    
                    <xsl:variable name="previous-value-for-output" select="if ($latest-change) then $latest-change/Field[@guid = $gUpdatedValue]/string() else ''"/>
                    <xsl:variable name="updated-value-for-output" select="string-join($current-record/Field[@guid = $gSegments]/Reference, '&lt;br&gt;&lt;br&gt;')"/>
                    
                    <ArcherRecord>
                        <Tracking_ID><xsl:value-of select="$current-record/@contentId"/></Tracking_ID>
                        <Previous_Value><xsl:value-of select="$previous-value-for-output"/></Previous_Value>
                        <Updated_Value><xsl:value-of select="$updated-value-for-output"/></Updated_Value>

                        <Current_Primary_Jurisdiction_AUs>
                            <xsl:variable name="primary-au-ids" select="$current-record/Field[@guid = $gAUPrimary]/Reference/@id"/>
                            <xsl:for-each select="$updated-tokens">
                                <xsl:variable name="segment-name" select="."/>
                                <xsl:variable name="au-ids-for-segment" select="map:keys($au-segment-map)[$au-segment-map(.) = $segment-name]"/>
                                <xsl:variable name="current-primary-au-ids" select="$au-ids-for-segment[. = $primary-au-ids]"/>
                                <xsl:for-each select="$current-primary-au-ids">
                                    <Assessable_Unit><xsl:value-of select="$current-record/Record[@contentId = .]/Field[@guid = $gAssessableUnitName]"/></Assessable_Unit>
                                </xsl:for-each>
                            </xsl:for-each>
                        </Current_Primary_Jurisdiction_AUs>

                        <Current_Cross_Border_AUs>
                            <xsl:variable name="cross-border-au-ids" select="$current-record/Field[@guid = $gAUCrossBorder]/Reference/@id"/>
                            <xsl:for-each select="$updated-tokens">
                                <xsl:variable name="segment-name" select="."/>
                                <xsl:variable name="au-ids-for-segment" select="map:keys($au-segment-map)[$au-segment-map(.) = $segment-name]"/>
                                <xsl:variable name="current-cross-border-au-ids" select="$au-ids-for-segment[. = $cross-border-au-ids]"/>
                                <xsl:for-each select="$current-cross-border-au-ids">
                                     <Assessable_Unit><xsl:value-of select="$current-record/Record[@contentId = .]/Field[@guid = $gAssessableUnitName]"/></Assessable_Unit>
                                </xsl:for-each>
                            </xsl:for-each>
                        </Current_Cross_Border_AUs>

                    </ArcherRecord>
                </xsl:if>
            </xsl:for-each>
        </ArcherRecords>
    </xsl:template>

</xsl:stylesheet>
