    async def check_proxy(self):
        """
        Performs a one-time, robust check to verify the proxy is active and routing traffic.
        This version provides a clearer, more logical sequence of log messages.
        """
        if not self.proxy:
            logging.info("Proxy is not enabled. Skipping verification.")
            return

        # --- REVISED LOGGING FLOW ---
        # 1. Announce the start of the verification process.
        proxy_url_to_log = f"http://{PROXY_USERNAME}:***@{PROXY_URL}"
        logging.info(f"Proxy is enabled. Starting verification for: {proxy_url_to_log}")
        
        IP_CHECK_SERVICES = [
            "https://api.ipify.org?format=json",
            "https://api.seeip.org/jsonip",
            "https://ipinfo.io/json"
        ]
        timeout = aiohttp.ClientTimeout(total=15)
        
        if not self.session:
            raise RuntimeError("Cannot check proxy status: ClientSession is not initialized.")

        # --- Step 1: Attempt to get the public IP with a DIRECT connection ---
        direct_ip = None
        logging.info("--> Step 1 of 2: Attempting to establish a direct connection...")
        for service_url in IP_CHECK_SERVICES:
            try:
                async with self.session.get(service_url, timeout=timeout, proxy=None) as response:
                    response.raise_for_status()
                    data = await response.json()
                    direct_ip = data.get("ip")
                    if direct_ip:
                        logging.info(f"    Direct connection successful. Public IP without proxy is: {direct_ip}")
                        break
            except Exception:
                continue
        
        if not direct_ip:
            logging.warning("    Could not establish a direct connection. This may be expected if a proxy is required.")

        # --- Step 2: Get the public IP WITH the proxy enabled ---
        proxy_ip = None
        logging.info("--> Step 2 of 2: Attempting to connect via proxy...")
        for service_url in IP_CHECK_SERVICES:
            try:
                async with self.session.get(service_url, proxy=self.proxy, timeout=timeout) as response:
                    if response.status == 407:
                        logging.critical("Proxy Verification Failed: 407 Proxy Authentication Required. Please check credentials.")
                        sys.exit("Exiting due to proxy authentication failure.")
                    
                    response.raise_for_status()
                    data = await response.json()
                    proxy_ip = data.get("ip")
                    if proxy_ip:
                        logging.info(f"    Proxy connection successful. The proxy's public IP is: {proxy_ip}")
                        break
            except Exception:
                continue

        # --- Step 3: Compare IPs and Determine Final Status ---
        if not proxy_ip:
            logging.critical("Proxy Verification Failed: Could not get a response through the proxy.")
            sys.exit("Exiting due to proxy connection failure.")

        if direct_ip and direct_ip == proxy_ip:
            logging.critical(f"Proxy Verification Failed: The IP address is the same with and without the proxy ({direct_ip}). The proxy is not routing traffic.")
            sys.exit("Exiting because proxy is not functional.")
        
        logging.info("Proxy verification successful. Traffic is correctly routed through the proxy.")
