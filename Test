import re
import argparse
from typing import Set, Tuple

def parse_log_file(file_path: str, is_debug: bool = False) -> Tuple[Set[str], int, int]:
    """
    Parses a log file to extract all unique Group IDs from 'Skipping' log lines.

    This version uses a highly specific regex tailored to match GUIDs to ensure
    accurate parsing of the log files.

    Args:
        file_path: The path to the log file.
        is_debug: Flag to enable printing of matched lines.

    Returns:
        A tuple containing:
        - A set of unique Group ID strings.
        - The total number of lines read from the file.
        - The number of lines that matched the 'Skipping' pattern.
    """
    # This regex is now hyper-specific. It looks for "Skipping Group ID" followed by
    # the exact 8-4-4-4-12 hexadecimal character format of a GUID.
    # This is the most robust way to ensure an accurate match.
    group_id_pattern = re.compile(
        r"Skipping Group ID ([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})",
        re.IGNORECASE
    )
    skipped_ids = set()
    lines_read = 0
    lines_matched = 0

    if is_debug:
        print(f"\n--- DEBUG: Inspecting lines from '{file_path}' for GUID pattern ---")

    try:
        with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:
            for i, line in enumerate(f, 1):
                lines_read += 1
                match = group_id_pattern.search(line)
                if match:
                    lines_matched += 1
                    # In debug mode, print the line that was successfully matched.
                    if is_debug:
                        print(f"  Line {i} MATCHED: {line.strip()}")
                    # group(1) captures just the GUID part of the pattern.
                    skipped_ids.add(match.group(1).strip())
    except FileNotFoundError:
        print(f"Error: The file '{file_path}' was not found.")
        exit(1)
        
    if is_debug:
        print("--- END DEBUG ---\n")
        
    return skipped_ids, lines_read, lines_matched

def compare_logs(file1_path: str, file2_path: str, debug_mode: bool):
    """Compares two log files to find differences in skipped Group IDs."""
    print(f"Comparing log files:\n- Old Log: {file1_path}\n- New Log: {file2_path}\n")

    ids_from_file1, read1, matched1 = parse_log_file(file1_path, debug_mode)
    ids_from_file2, read2, matched2 = parse_log_file(file2_path, debug_mode)

    print("--- Diagnostics ---")
    print(f"File 1 ('{file1_path}'):")
    print(f"  - Total lines read:       {read1:,}")
    print(f"  - Lines matching pattern: {matched1:,}")
    print(f"  - Unique skipped IDs found: {len(ids_from_file1):,}")
    print()
    print(f"File 2 ('{file2_path}'):")
    print(f"  - Total lines read:       {read2:,}")
    print(f"  - Lines matching pattern: {matched2:,}")
    print(f"  - Unique skipped IDs found: {len(ids_from_file2):,}")
    print("-" * 20)

    removed_ids = ids_from_file1 - ids_from_file2
    added_ids = ids_from_file2 - ids_from_file1

    if not removed_ids and not added_ids:
        print("\n✅ No differences found. The set of skipped groups is identical.")
        if matched1 == 0 and matched2 == 0:
            print("   Warning: The pattern 'Skipping Group ID <GUID>' was not found in either file.")
    else:
        if added_ids:
            print(f"\n➕ Groups ADDED to the skip list in the new log ({len(added_ids):,})")
            for group_id in sorted(list(added_ids)):
                print(f"  - {group_id}")
            print()
        if removed_ids:
            print(f"\n➖ Groups REMOVED from the skip list in the new log ({len(removed_ids):,})")
            for group_id in sorted(list(removed_ids)):
                print(f"  - {group_id}")
            print()

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Compare two application logs to find differences in skipped Group IDs.")
    parser.add_argument("old_log", help="The path to the first or older log file.")
    parser.add_argument("new_log", help="The path to the second or newer log file.")
    parser.add_argument("--debug", action="store_true", help="Enable debug mode to print matched lines.")
    
    args = parser.parse_args()
    compare_logs(args.old_log, args.new_log, args.debug)
