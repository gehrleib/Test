import argparse
from collections import Counter
from typing import List

def find_duplicate_skips(file_path: str) -> None:
    """
    Parses a single log file to find Group IDs that are skipped multiple times.

    Args:
        file_path: The path to the log file to analyze.
    """
    key_phrase = "Skipping Group ID"
    # We use a list this time to keep all occurrences, including duplicates.
    all_skipped_ids: List[str] = []
    lines_read = 0

    try:
        # Open with 'utf-16' encoding to correctly read PowerShell output logs.
        with open(file_path, 'r', encoding='utf-16') as f:
            for line in f:
                lines_read += 1
                if key_phrase.lower() in line.lower():
                    try:
                        # Split the line to isolate the Group ID.
                        post_part = line.split(key_phrase, 1)[1]
                        group_id = post_part.split(':', 1)[0]
                        all_skipped_ids.append(group_id.strip())
                    except IndexError:
                        continue
    except FileNotFoundError:
        print(f"Error: The file '{file_path}' was not found.")
        exit(1)
    except Exception as e:
        print(f"An error occurred while reading '{file_path}': {e}")
        exit(1)

    # --- Analysis and Reporting ---
    print(f"\n--- Analysis for: {file_path} ---")
    print(f"Total lines read: {lines_read:,}")
    print(f"Total 'Skipping' entries found: {len(all_skipped_ids):,}")
    print(f"Unique skipped IDs found: {len(set(all_skipped_ids)):,}")
    print("-" * 30)

    # Count the occurrences of each ID.
    id_counts = Counter(all_skipped_ids)

    # Filter for IDs that appeared more than once.
    duplicate_ids = {id: count for id, count in id_counts.items() if count > 1}

    if duplicate_ids:
        print(f"✅ Found {len(duplicate_ids)} Group IDs that were skipped multiple times:")
        # Sort by count (descending) and then by ID (ascending) for clear output.
        sorted_duplicates = sorted(duplicate_ids.items(), key=lambda item: (-item[1], item[0]))
        for group_id, count in sorted_duplicates:
            print(f"  - ID: {group_id} (Skipped {count} times)")
    else:
        print("✅ No duplicate skipped Group IDs were found in the log file.")
    
    print("-" * 30)


if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description="Finds and lists Group IDs that were skipped multiple times in a log file."
    )
    parser.add_argument("log_file", help="The path to the application log file to analyze.")
    
    args = parser.parse_args()
    find_duplicate_skips(args.log_file)
